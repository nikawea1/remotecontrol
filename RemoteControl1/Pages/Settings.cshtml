@page
@model RemoteControl1.Pages.SettingsModel
@{
    ViewData["Title"] = "Настройки";
}

<div id="settingsPage" class="container main-content page-content">
    <div class="page-header-row">
        <div class="page-heading">
            <span class="page-heading-icon" aria-hidden="true">
                @await Html.PartialAsync("_RcIcon", "settings")
            </span>
            <div>
                <h1 class="page-title">Настройки</h1>
            </div>
        </div>
    </div>

    <div class="settings-layout">
        <aside class="settings-nav" aria-label="Разделы настроек">
            <a href="#settingsInterface" class="settings-nav-link">
                <i class="fas fa-palette"></i>
                <span>Интерфейс</span>
            </a>
            <a href="#settingsNotifications" class="settings-nav-link">
                <i class="far fa-bell"></i>
                <span>Уведомления</span>
            </a>
            <a href="#settingsWorkflow" class="settings-nav-link">
                <i class="fas fa-list-check"></i>
                <span>Рабочий процесс</span>
            </a>
            <a href="#settingsAccess" class="settings-nav-link">
                <i class="far fa-user"></i>
                <span>Профиль и доступ</span>
            </a>
        </aside>

        <div class="settings-sections">
            <section class="card settings-card" id="settingsInterface">
                <div class="settings-section-head">
                    <span class="settings-section-icon">@await Html.PartialAsync("_RcIcon", "settings")</span>
                    <div>
                        <h2>Интерфейс</h2>
                        <p>Внешний вид, плотность и визуальная читаемость.</p>
                    </div>
                </div>

                <div class="settings-list">
                    <div class="settings-row">
                        <div>
                            <div class="settings-row-title">Повышенный контраст</div>
                            <div class="settings-row-text">Более заметные границы карточек, таблиц и полей.</div>
                        </div>
                        <button class="btn btn-outline" type="button" id="settingsContrastToggle" onclick="toggleHighContrastMode()">
                            <i class="fas fa-circle-half-stroke"></i>
                            Включить
                        </button>
                    </div>

                    <div class="settings-row">
                        <div>
                            <div class="settings-row-title">Компактная плотность</div>
                            <div class="settings-row-text">Меньше пустого места в карточках, таблицах и списках.</div>
                        </div>
                        <button class="btn btn-outline" type="button" id="settingsCompactToggle" onclick="toggleCompactDensity()">
                            <i class="fas fa-compress"></i>
                            Включить
                        </button>
                    </div>
                </div>
            </section>

            <section class="card settings-card" id="settingsNotifications">
                <div class="settings-section-head">
                    <span class="settings-section-icon">@await Html.PartialAsync("_RcIcon", "calendar")</span>
                    <div>
                        <h2>Уведомления</h2>
                        <p>События задач, заявок и сроков.</p>
                    </div>
                </div>

                <div class="settings-list">
                    <div class="settings-row">
                        <div>
                            <div class="settings-row-title">Центр уведомлений</div>
                            <div class="settings-row-text">Новые события отображаются рядом с профилем.</div>
                        </div>
                        <span class="settings-status-pill is-active">Включено</span>
                    </div>

                    <div class="settings-row">
                        <div>
                            <div class="settings-row-title">События задач</div>
                            <div class="settings-row-text">Сроки, проверки и ручные заявки попадают в общий поток.</div>
                        </div>
                        <span class="settings-status-pill">По проекту</span>
                    </div>
                </div>
            </section>

            <section class="card settings-card" id="settingsWorkflow">
                <div class="settings-section-head">
                    <span class="settings-section-icon">@await Html.PartialAsync("_RcIcon", "tasks")</span>
                    <div>
                        <h2>Рабочий процесс</h2>
                        <p>Быстрые переходы к задачам и учёту времени.</p>
                    </div>
                </div>

                <div class="settings-list">
                    <div class="settings-row">
                        <div>
                            <div class="settings-row-title">Задачи</div>
                            <div class="settings-row-text">Списки задач, сроки, приоритеты и статусы.</div>
                        </div>
                        <a class="btn btn-outline" asp-page="/Tasks">
                            <i class="fas fa-calendar-days"></i>
                            Открыть
                        </a>
                    </div>

                    <div class="settings-row">
                        <div>
                            <div class="settings-row-title">Трекер</div>
                            <div class="settings-row-text">Рабочее время, сессии и ручные заявки.</div>
                        </div>
                        <a class="btn btn-outline" asp-page="/Tracker">
                            <i class="fas fa-stopwatch"></i>
                            Открыть
                        </a>
                    </div>
                </div>
            </section>

            <section class="card settings-card" id="settingsAccess">
                <div class="settings-section-head">
                    <span class="settings-section-icon">@await Html.PartialAsync("_RcIcon", "profile")</span>
                    <div>
                        <h2>Профиль и доступ</h2>
                        <p>Личные данные, контакты и рабочие параметры.</p>
                    </div>
                </div>

                <div class="settings-list">
                    <div class="settings-row">
                        <div>
                            <div class="settings-row-title">Профиль</div>
                            <div class="settings-row-text">Имя, контакты, должность, режим работы и ставка.</div>
                        </div>
                        <a class="btn btn-primary" asp-page="/Profile">
                            <i class="far fa-user"></i>
                            Открыть профиль
                        </a>
                    </div>
                </div>
            </section>
        </div>
    </div>
</div>
