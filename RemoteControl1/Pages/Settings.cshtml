@page
@model RemoteControl1.Pages.SettingsModel
@{
    ViewData["Title"] = "Настройки";
}

<div id="settingsPage" class="container main-content page-content">
    <div class="page-header-row">
        <div class="page-heading">
            <span class="page-heading-icon" aria-hidden="true">
                <i class="fas fa-sliders"></i>
            </span>
            <div>
                <h1 class="page-title">Настройки</h1>
                <p class="page-subtitle">Общие параметры интерфейса, уведомлений и рабочего процесса.</p>
            </div>
        </div>
    </div>

    <div class="settings-grid settings-grid-wide">
        <section class="card settings-card">
            <div class="card-header">
                <h2 class="card-title">
                    <i class="fas fa-palette"></i>
                    Интерфейс
                </h2>
                <span class="settings-card-badge">Вид</span>
            </div>

            <div class="settings-row">
                <div>
                    <div class="settings-row-title">Тёмная тема</div>
                    <div class="settings-row-text">Кнопка-заглушка уже находится в верхней панели. Полное переключение палитры можно подключить следующим шагом.</div>
                </div>
                <button class="btn btn-outline" type="button" onclick="toggleThemePlaceholder()">
                    <i class="fas fa-moon"></i>
                    Скоро
                </button>
            </div>

            <div class="settings-row">
                <div>
                    <div class="settings-row-title">Плотность интерфейса</div>
                    <div class="settings-row-text">Карточки, таблицы и формы приведены к единой средней плотности: меньше пустоты, но без перегруза.</div>
                </div>
                <span class="settings-status-pill">Стандарт</span>
            </div>
        </section>

        <section class="card settings-card">
            <div class="card-header">
                <h2 class="card-title">
                    <i class="far fa-bell"></i>
                    Уведомления
                </h2>
                <span class="settings-card-badge">Центр событий</span>
            </div>

            <div class="settings-row">
                <div>
                    <div class="settings-row-title">Панель уведомлений</div>
                    <div class="settings-row-text">Иконка рядом с пользователем показывает новые события красной точкой и раскрывает список уведомлений.</div>
                </div>
                <span class="settings-status-pill is-active">Включено</span>
            </div>

            <div class="settings-row">
                <div>
                    <div class="settings-row-title">События задач</div>
                    <div class="settings-row-text">Важные изменения по срокам, проверкам и заявкам отображаются в общем центре уведомлений.</div>
                </div>
                <span class="settings-status-pill">По проекту</span>
            </div>
        </section>

        <section class="card settings-card">
            <div class="card-header">
                <h2 class="card-title">
                    <i class="fas fa-list-check"></i>
                    Рабочий процесс
                </h2>
                <span class="settings-card-badge">Задачи</span>
            </div>

            <div class="settings-row">
                <div>
                    <div class="settings-row-title">Сроки задач</div>
                    <div class="settings-row-text">Задачи сгруппированы по периодам: просрочено, сегодня, скоро и без срока. Это помогает видеть риски без лишнего шума.</div>
                </div>
                <a class="btn btn-outline" asp-page="/Tasks">
                    <i class="fas fa-calendar-days"></i>
                    Открыть
                </a>
            </div>

            <div class="settings-row">
                <div>
                    <div class="settings-row-title">Учёт времени</div>
                    <div class="settings-row-text">Основные параметры трекера и ручных заявок остаются в разделе трекера, чтобы профиль не был перегружен.</div>
                </div>
                <a class="btn btn-outline" asp-page="/Tracker">
                    <i class="fas fa-stopwatch"></i>
                    Трекер
                </a>
            </div>
        </section>

        <section class="card settings-card">
            <div class="card-header">
                <h2 class="card-title">
                    <i class="far fa-user"></i>
                    Профиль и доступ
                </h2>
                <span class="settings-card-badge">Аккаунт</span>
            </div>

            <div class="settings-row">
                <div>
                    <div class="settings-row-title">Личные данные</div>
                    <div class="settings-row-text">Имя, контакты, должность и рабочая ставка хранятся в профиле. Здесь оставлены только общие настройки продукта.</div>
                </div>
                <a class="btn btn-primary" asp-page="/Profile">
                    <i class="far fa-user"></i>
                    Открыть профиль
                </a>
            </div>
        </section>
    </div>
</div>
