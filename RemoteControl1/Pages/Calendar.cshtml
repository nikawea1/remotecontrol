@page
@* Файл: RemoteControl1/Pages/Calendar.cshtml *@
@model RemoteControl1.Pages.CalendarModel
@{
    ViewData["Title"] = "Календарь";
}

@Html.AntiForgeryToken()

<div id="calendarPage" class="container main-content page-content">
    <div class="page-content">
        <div class="calendar-page-header">
            <div>
                <h1 class="calendar-page-title">Календарь</h1>
                <p class="calendar-page-subtitle">Управляйте вашими событиями и задачами</p>
            </div>

            @if (!Model.IsEmployee)
            {
                <button class="btn btn-primary calendar-create-btn" type="button" onclick="openCalendarModal()">
                    <i class="fas fa-plus"></i> Создать событие
                </button>
            }
        </div>

        <div class="calendar-layout-modern">
            <div class="calendar-board card">
                <div class="calendar-board-header">
                    <div class="calendar-title-wrap">
                        <button class="calendar-title-btn" type="button" onclick="toggleMiniCalendar()">
                            <span id="calendarPageMonthTitle"></span>
                            <i class="fas fa-chevron-down calendar-title-caret"></i>
                        </button>

                        <div id="miniCalendarPopup" class="mini-calendar-popup hidden">
                            <div class="mini-calendar-top">
                                <button type="button" class="mini-calendar-nav-btn" onclick="changeMiniCalendarYear(-1)">
                                    <i class="fas fa-chevron-left"></i>
                                </button>
                                <span id="miniCalendarYearLabel"></span>
                                <button type="button" class="mini-calendar-nav-btn" onclick="changeMiniCalendarYear(1)">
                                    <i class="fas fa-chevron-right"></i>
                                </button>
                            </div>

                            <div id="miniCalendarMonths" class="mini-calendar-months-grid"></div>
                        </div>
                    </div>

                    <div class="calendar-board-nav">
                        <button class="calendar-nav-btn" type="button" onclick="prevCalendarMonth()">
                            <i class="fas fa-chevron-left"></i>
                        </button>
                        <button class="calendar-nav-btn" type="button" onclick="nextCalendarMonth()">
                            <i class="fas fa-chevron-right"></i>
                        </button>
                    </div>
                </div>

                <div class="calendar-weekdays-modern">
                    <div>Пн</div>
                    <div>Вт</div>
                    <div>Ср</div>
                    <div>Чт</div>
                    <div>Пт</div>
                    <div>Сб</div>
                    <div>Вс</div>
                </div>

                <div id="calendarGridMain" class="calendar-grid-modern"></div>
            </div>

            <div class="calendar-sidebar-modern card">
                <div class="calendar-sidebar-header">
                    <h3>Предстоящие события</h3>
                </div>

                <div id="selectedCalendarDateText" class="calendar-selected-date-modern"></div>
                <div id="calendarEventsListMain" class="calendar-events-list-modern"></div>
            </div>
        </div>
    </div>
</div>

@if (!Model.IsEmployee)
{
    <div class="modal" id="calendarModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title" id="calendarModalTitle">Новое событие</h3>
                <button class="modal-close" type="button" onclick="closeModal('calendarModal')">&times;</button>
            </div>

            <div class="modal-body">
                <input type="hidden" id="calendarEventId" value="">

                <div class="form-group">
                    <label class="form-label">Название</label>
                    <input type="text" class="form-control" id="calendarTitle" placeholder="Митап команды">
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Дата</label>
                        <input type="date" class="form-control" id="calendarDate">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Время</label>
                        <input type="time" class="form-control" id="calendarTime">
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Тип события</label>
                        <select class="form-control" id="calendarType">
                            <option value="meeting">Встреча</option>
                            <option value="meetup">Митап</option>
                            <option value="task">Задача</option>
                            <option value="deadline">Дедлайн</option>
                            <option value="review">Проверка</option>
                            <option value="call">Звонок</option>
                            <option value="presentation">Презентация</option>
                            <option value="personal">Личное</option>
                            <option value="reminder">Напоминание</option>
                            <option value="other">Другое</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Проект</label>
                        <select class="form-control" id="calendarProjectId">
                            <option value="">Без проекта</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Ссылка / место</label>
                    <input type="text" class="form-control" id="calendarLocation" placeholder="Ссылка на Meet или кабинет">
                </div>

                <div class="form-group">
                    <label class="form-label">Описание</label>
                    <textarea class="form-control" id="calendarDescription" rows="3" placeholder="Описание события"></textarea>
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-danger hidden" id="calendarDeleteBtn" type="button" onclick="deleteCalendarEvent()">
                    <i class="fas fa-trash"></i> Удалить
                </button>
                <button class="btn btn-outline" type="button" onclick="closeModal('calendarModal')">Отмена</button>
                <button class="btn btn-primary" type="button" onclick="saveCalendarEvent()">
                    <i class="fas fa-save"></i> Сохранить
                </button>
            </div>
        </div>
    </div>
}

<script>
    window.remoteControlData = {
        currentUserId: @Model.CurrentUserId,
        currentUserRole: '@Model.CurrentUserRole',
        isAdmin: @Model.IsAdmin.ToString().ToLower(),
        isManager: @Model.IsManager.ToString().ToLower(),
        isEmployee: @Model.IsEmployee.ToString().ToLower(),
        calendarEvents: @Html.Raw(Model.CalendarEventsJson ?? "[]"),
        projects: @Html.Raw(Model.ProjectsJson ?? "[]")
    };
</script>

@section Scripts {
    <script src="~/js/calendar.js" asp-append-version="true"></script>
}
