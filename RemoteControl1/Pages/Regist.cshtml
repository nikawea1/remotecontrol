        <div class="auth-right">
            <div class="auth-header">
                <h2>Создать аккаунт</h2>
                <p>Уже есть аккаунт? <a href="/Auth">Войти</a></p>
            </div>

            <form class="auth-form" method="post">
                @Html.AntiForgeryToken()

                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label"><i class="fas fa-user"></i> Имя</label>
                        <div class="input-wrapper">
                            <i class="fas fa-user input-icon"></i>
                            <input type="text" class="form-control" asp-for="Input.FirstName" placeholder="Введите имя" required>
                        </div>
                        <div class="field-error" asp-validation-for="Input.FirstName"></div>
                    </div>

                    <div class="form-group">
                        <label class="form-label"><i class="fas fa-user-circle"></i> Фамилия</label>
                        <div class="input-wrapper">
                            <i class="fas fa-user-circle input-icon"></i>
                            <input type="text" class="form-control" asp-for="Input.LastName" placeholder="Введите фамилию" required>
                        </div>
                        <div class="field-error" asp-validation-for="Input.LastName"></div>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label"><i class="fas fa-envelope"></i> Email</label>
                    <div class="input-wrapper">
                        <i class="fas fa-envelope input-icon"></i>
                        <input type="email" class="form-control" asp-for="Input.Email" placeholder="Введите email" required>
                    </div>
                    <div class="field-error" asp-validation-for="Input.Email"></div>
                </div>

                <div class="form-group">
                    <label class="form-label"><i class="fas fa-lock"></i> Пароль</label>
                    <div class="input-wrapper">
                        <i class="fas fa-lock input-icon"></i>
                        <input type="password" class="form-control" id="registerPassword" asp-for="Input.Password" placeholder="••••••••" required>
                        <button type="button" class="password-toggle" onclick="togglePassword('registerPassword', this)">
                            <i class="fas fa-lock"></i>
                        </button>
                    </div>
                    <div class="field-error" asp-validation-for="Input.Password"></div>
                </div>

                <div class="form-group">
                    <label class="form-label"><i class="fas fa-lock"></i> Подтвердите пароль</label>
                    <div class="input-wrapper">
                        <i class="fas fa-lock input-icon"></i>
                        <input type="password" class="form-control" id="confirmPassword" asp-for="Input.ConfirmPassword" placeholder="••••••••" required>
                        <button type="button" class="password-toggle" onclick="togglePassword('confirmPassword', this)">
                            <i class="fas fa-lock"></i>
                        </button>
                    </div>
                    <div class="field-error" asp-validation-for="Input.ConfirmPassword"></div>
                </div>

                <div class="form-group checkbox-group">
                    <input type="checkbox" id="terms" checked required>
                    <label for="terms">Я принимаю <a href="#" onclick="showNotification('Условия использования'); return false;">условия использования</a> и <a href="#" onclick="showNotification('Политика конфиденциальности'); return false;">политику конфиденциальности</a></label>
                </div>

                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-user-plus"></i> Зарегистрироваться
                </button>

                @if (!string.IsNullOrWhiteSpace(Model.Error))
                {
                    <div class="error-box">@Model.Error</div>
                }
            </form>
        </div>
