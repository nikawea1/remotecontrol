@page
@using Microsoft.AspNetCore.Http
@* Файл: RemoteControl1/Pages/Users.cshtml *@
@model RemoteControl1.Pages.UsersModel
@{
    ViewData["Title"] = "Сотрудники";
    var sessionUserName = HttpContext.Session.GetString("user_name") ?? "";
    var sessionUserEmail = HttpContext.Session.GetString("user_email") ?? "";
    var sessionUserLogin = HttpContext.Session.GetString("user_login") ?? "";
}

<div id="usersPage" class="container main-content page-content">
    <div class="page-content">
        <div class="content-header">
            <div class="page-heading">
                <span class="page-heading-icon" aria-hidden="true">
                    <i class="fas fa-user-group"></i>
                </span>
                <div>
                    <h1 class="page-title">Сотрудники</h1>
                    <p class="page-subtitle">Команда, нагрузка, производительность и заявки в одном разделе.</p>
                </div>
            </div>

            <button class="btn btn-primary" onclick="openUserModal()" id="usersPageAddBtn">
                <i class="fas fa-user-plus"></i> Добавить сотрудника
            </button>
        </div>

        <div class="card" style="padding-bottom: 14px;">
            <div class="admin-tabs">
                <button type="button" class="admin-tab-btn active" onclick="showAdminTab('employees', this)">
                    <i class="fas fa-user-group"></i> Сотрудники
                </button>
                <button type="button" class="admin-tab-btn" onclick="showAdminTab('workload', this)">
                    <i class="fas fa-briefcase"></i> Нагрузка
                </button>
                <button type="button" class="admin-tab-btn" onclick="showAdminTab('productivity', this)">
                    <i class="fas fa-chart-line"></i> Производительность
                </button>
                <button type="button" class="admin-tab-btn" onclick="showAdminTab('salary', this)">
                    <i class="fas fa-wallet"></i> Оплата
                </button>
                <button type="button" class="admin-tab-btn" onclick="showAdminTab('bonuses', this)">
                    <i class="fas fa-gift"></i> Бонусы
                </button>
                <button type="button" class="admin-tab-btn" onclick="showAdminTab('control', this)">
                    <i class="fas fa-shield-alt"></i> Контроль
                </button>
            </div>
        </div>

        <div id="adminEmployeesTab" class="admin-tab-content">
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-user-group"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" id="adminEmployeesTotal">0</div>
                        <div class="stat-label">Всего сотрудников</div>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-user-slash"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" id="adminEmployeesActive">0</div>
                        <div class="stat-label">Активные</div>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-user-tie"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" id="adminManagersCount">0</div>
                        <div class="stat-label">Руководители</div>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-shield-halved"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" id="adminAdminsCount">0</div>
                        <div class="stat-label">Администраторы</div>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-money-bill-wave"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" id="adminAverageRate">0</div>
                        <div class="stat-label">Средняя ставка</div>
                    </div>
                </div>
            </div>

            <div class="filters-bar">
                <div class="filter-group">
                    <i class="fas fa-magnifying-glass"></i>
                    <input type="search"
                           class="filter-input"
                           id="employeeSearch"
                           name="rc-users-table-search"
                           value=""
                           placeholder="Поиск по ФИО, логину, email..."
                           autocomplete="off"
                           aria-autocomplete="none"
                           inputmode="search"
                           autocapitalize="off"
                           autocorrect="off"
                           spellcheck="false"
                           readonly
                           onfocus="this.removeAttribute('readonly')"
                           data-lpignore="true"
                           data-form-type="other"
                           onkeyup="renderUsersTable()">
                </div>

                <div class="filter-group">
                    <i class="fas fa-user-tag"></i>
                    <select class="filter-select" id="employeeRoleFilter" onchange="renderUsersTable()">
                        <option value="all">Все роли</option>
                        <option value="employee">Сотрудники</option>
                        <option value="manager">Руководители</option>
                        <option value="admin">Администраторы</option>
                    </select>
                </div>

                <div class="filter-group">
                    <i class="fas fa-toggle-on"></i>
                    <select class="filter-select" id="employeeStatusFilter" onchange="renderUsersTable()">
                        <option value="all">Все статусы</option>
                        <option value="active">Активные</option>
                        <option value="blocked">Заблокированные</option>
                    </select>
                </div>
            </div>

            <div class="card">
                <div class="table-container">
                    <table class="table admin-employees-table">
                        <colgroup>
                            <col style="width:5%">
                            <col style="width:12%">
                            <col style="width:9%">
                            <col style="width:11%">
                            <col style="width:13%">
                            <col style="width:10%">
                            <col style="width:8%">
                            <col style="width:9%">
                            <col style="width:10%">
                            <col style="width:13%">
                        </colgroup>
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Сотрудник</th>
                                <th>Логин</th>
                                <th>Должность</th>
                                <th>Роль</th>
                                <th>Ставка</th>
                                <th>Активных<br>задач</th>
                                <th>Часов по<br>задачам</th>
                                <th>Статус</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody id="usersTableBody"></tbody>
                    </table>
                </div>
            </div>
        </div>

        <div id="adminWorkloadTab" class="admin-tab-content hidden">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Нагрузка сотрудников</h3>
                </div>

                <div class="table-container">
                    <table class="table admin-workload-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Сотрудник</th>
                                <th>Активных<br>задач</th>
                                <th>Выполнено</th>
                                <th>Просрочено</th>
                                <th>План по<br>задачам</th>
                                <th>По<br>задачам</th>
                                <th>Рабочий<br>день</th>
                                <th>Простой</th>
                                <th>Отклонение</th>
                            </tr>
                        </thead>
                        <tbody id="workloadTableBody"></tbody>
                    </table>
                </div>
            </div>
        </div>

        <div id="adminProductivityTab" class="admin-tab-content hidden">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Производительность</h3>
                </div>

                <div class="table-container">
                    <table class="table admin-productivity-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Сотрудник</th>
                                <th>Фактические<br>часы</th>
                                <th>Активные<br>задачи</th>
                                <th>Выполненные<br>задачи</th>
                                <th>Индекс</th>
                                <th>Состояние</th>
                            </tr>
                        </thead>
                        <tbody id="productivityTableBody"></tbody>
                    </table>
                </div>
            </div>
        </div>

        <div id="adminSalaryTab" class="admin-tab-content hidden">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Расчет оплаты</h3>
                    <button class="btn btn-outline" type="button" onclick="exportAdminSalaryCsv()">
                        <i class="fas fa-file-csv"></i> CSV
                    </button>
                </div>

                <div class="table-container">
                    <table class="table admin-salary-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Сотрудник</th>
                                <th>Учтённые<br>часы</th>
                                <th>Рабочий<br>день</th>
                                <th>Простой</th>
                                <th>Ставка</th>
                                <th>Сумма</th>
                            </tr>
                        </thead>
                        <tbody id="salaryTableBody"></tbody>
                    </table>
                </div>
            </div>
        </div>

        <div id="adminBonusesTab" class="admin-tab-content hidden">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Бонусы</h3>
                </div>

                <div class="table-container">
                    <table class="table admin-bonuses-table">
                        <colgroup>
                            <col style="width:4%">
                            <col style="width:12%">
                            <col style="width:8%">
                            <col style="width:8%">
                            <col style="width:10%">
                            <col style="width:10%">
                            <col style="width:12%">
                            <col style="width:24%">
                            <col style="width:12%">
                        </colgroup>
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Сотрудник</th>
                                <th>План</th>
                                <th>Факт</th>
                                <th>Выполнение</th>
                                <th>Отклонение</th>
                                <th>Статус<br>бонуса</th>
                                <th>Основание</th>
                                <th>Сумма</th>
                            </tr>
                        </thead>
                        <tbody id="bonusesTableBody"></tbody>
                    </table>
                </div>
            </div>
        </div>

        <div id="adminControlTab" class="admin-tab-content hidden">
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-triangle-exclamation"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" id="controlOverloaded">0</div>
                        <div class="stat-label">Перегружены</div>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-hourglass-half"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" id="controlUnderloaded">0</div>
                        <div class="stat-label">Недогружены</div>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-user-check"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" id="controlNoActivity">0</div>
                        <div class="stat-label">Без активности</div>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon"><i class="far fa-circle-pause"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" id="controlHighIdle">0</div>
                        <div class="stat-label">Высокий простой</div>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Контроль отклонений</h3>
                </div>
                <div id="controlList"></div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Заявки на ручное время</h3>
                </div>

                <div class="filters-bar manual-requests-filters">
                    <div class="filter-group">
                        <i class="fas fa-magnifying-glass"></i>
                        <input type="search"
                               class="filter-input"
                               id="manualRequestSearch"
                               placeholder="Поиск по сотруднику, задаче, проекту, комментарию..."
                               autocomplete="off"
                               oninput="renderManualTimeRequests()">
                    </div>

                    <div class="filter-group">
                        <i class="fas fa-circle-notch"></i>
                        <select class="filter-select" id="manualRequestStatusFilter" onchange="renderManualTimeRequests()">
                            <option value="all">Все статусы</option>
                            <option value="pending">Ожидание</option>
                            <option value="needs_revision">На доработке</option>
                            <option value="approved">Одобрено</option>
                            <option value="rejected">Отклонено</option>
                        </select>
                    </div>

                    <div class="filter-group">
                        <i class="fas fa-layer-group"></i>
                        <select class="filter-select" id="manualRequestReasonFilter" onchange="renderManualTimeRequests()">
                            <option value="all">Все причины</option>
                        </select>
                    </div>

                    <div class="filter-group">
                        <i class="fas fa-folder-open"></i>
                        <select class="filter-select" id="manualRequestProjectFilter" onchange="renderManualTimeRequests()">
                            <option value="all">Все проекты</option>
                        </select>
                    </div>

                    <div class="filter-group">
                        <i class="fas fa-sort"></i>
                        <select class="filter-select" id="manualRequestSortFilter" onchange="renderManualTimeRequests()">
                            <option value="newest">Сначала новые</option>
                            <option value="oldest">Сначала старые</option>
                            <option value="hours_desc">Часы: больше</option>
                            <option value="hours_asc">Часы: меньше</option>
                            <option value="status">По статусу</option>
                        </select>
                    </div>

                    <button class="btn btn-outline" type="button" onclick="resetManualRequestFilters()">
                        <i class="fas fa-rotate-left"></i> Сбросить
                    </button>
                </div>

                <div class="table-container">
                    <table class="table admin-manual-requests-table" id="manualRequestsTable">
                        <colgroup>
                            <col style="width:4%">
                            <col style="width:8%">
                            <col style="width:14%">
                            <col style="width:10%">
                            <col style="width:5%">
                            <col style="width:9%">
                            <col style="width:5%">
                            <col style="width:13%">
                            <col style="width:16%">
                            <col style="width:16%">
                        </colgroup>
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Сотрудник</th>
                                <th>Задача</th>
                                <th>Проект</th>
                                <th>Часы</th>
                                <th>Комментарии</th>
                                <th>Файл</th>
                                <th>Статус</th>
                                <th>Дата заявки</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody id="manualTimeRequestsBody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal" id="userModal">
    <div class="modal-content">
        <div class="modal-header">
            <h3 class="modal-title" id="userModalTitle">Новый сотрудник</h3>
            <button class="modal-close" onclick="closeModal('userModal')">&times;</button>
        </div>

        <div class="modal-body">
            <input type="hidden" id="userEditId" value="0">

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Фамилия *</label>
                    <input type="text" class="form-control" id="uLastName" placeholder="Иванов">
                </div>
                <div class="form-group">
                    <label class="form-label">Имя *</label>
                    <input type="text" class="form-control" id="uFirstName" placeholder="Ника">
                </div>
                <div class="form-group">
                    <label class="form-label">Отчество</label>
                    <input type="text" class="form-control" id="uMiddleName" placeholder="Ивановна">
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Логин *</label>
                    <input type="text" class="form-control" id="uLogin" placeholder="i.ivanov" autocomplete="new-username">
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Пароль *</label>
                    <input type="password" class="form-control" id="uPass" placeholder="Введите пароль" autocomplete="new-password">
                </div>
                <div class="form-group">
                    <label class="form-label">Подтверждение пароля *</label>
                    <input type="password" class="form-control" id="uPass2" placeholder="Повторите пароль" autocomplete="new-password">
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Должность *</label>
                    <input type="text" class="form-control" id="uPosition" placeholder="Разработчик">
                </div>
                <div class="form-group">
                    <label class="form-label">Часовая ставка (руб.) *</label>
                    <input type="number" class="form-control" id="uRate" value="1500" min="0">
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Вид работы *</label>
                    <select class="form-control" id="uWorkMode" onchange="toggleWorkModeFields('u')">
                        <option value="fixed">Фиксированный</option>
                        <option value="flexible">Гибкий</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">Норма часов в день *</label>
                    <input type="number" class="form-control" id="uRequiredDailyHours" value="8" min="0" step="0.5">
                </div>
            </div>

            <div class="form-row workmode-fixed-fields" id="uFixedWorkFields">
                <div class="form-group">
                    <label class="form-label">Начало рабочего дня</label>
                    <input type="time" class="form-control" id="uPlannedStartTime" value="09:00">
                </div>

                <div class="form-group">
                    <label class="form-label">Конец рабочего дня</label>
                    <input type="time" class="form-control" id="uPlannedEndTime" value="18:00">
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Роль *</label>
                    <select class="form-control" id="uRole">
                        <option value="employee">Сотрудник</option>
                        <option value="manager">Руководитель</option>
                        <option value="admin">Администратор</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Email</label>
                    <input type="email" class="form-control" id="uEmail" placeholder="i.ivanov@mkp.by" autocomplete="email">
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Телефон</label>
                <input type="tel" class="form-control" id="uPhone" placeholder="+375 29 123-45-67" autocomplete="tel">
            </div>

            <div class="form-group">
                <label class="form-label">Статус</label>
                <select class="form-control" id="uStatus">
                    <option value="active" selected>Активен</option>
                    <option value="blocked">Заблокирован</option>
                </select>
            </div>
        </div>

        <div class="modal-footer">
            <button class="btn btn-outline" onclick="closeModal('userModal')">Отмена</button>
            <button class="btn btn-primary" onclick="saveUser()" id="saveUserBtn">
                <i class="fas fa-floppy-disk"></i> Сохранить
            </button>
        </div>
    </div>
</div>

<div class="modal" id="editUserModal">
    <div class="modal-content">
        <div class="modal-header">
            <h3 class="modal-title">Редактирование сотрудника</h3>
            <button class="modal-close" onclick="closeModal('editUserModal')">&times;</button>
        </div>

        <div class="modal-body">
            <input type="hidden" id="editUserId">

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Фамилия *</label>
