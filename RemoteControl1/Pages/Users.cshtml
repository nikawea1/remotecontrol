            </div>

            <div class="form-row workmode-fixed-fields" id="editUFixedWorkFields">
                <div class="form-group">
                    <label class="form-label">Начало рабочего дня</label>
                    <input type="time" class="form-control" id="editUPlannedStartTime" value="09:00">
                </div>

                <div class="form-group">
                    <label class="form-label">Конец рабочего дня</label>
                    <input type="time" class="form-control" id="editUPlannedEndTime" value="18:00">
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Email</label>
                    <input type="email" class="form-control" id="editUEmail" autocomplete="email">
                </div>
                <div class="form-group">
                    <label class="form-label">Телефон</label>
                    <input type="tel" class="form-control" id="editUPhone" autocomplete="tel">
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Статус</label>
                <select class="form-control" id="editUStatus">
                    <option value="active">Активен</option>
                    <option value="blocked">Заблокирован</option>
                </select>
            </div>
        </div>

        <div class="modal-footer">
            <button class="btn btn-outline" onclick="closeModal('editUserModal')">Отмена</button>
            <button class="btn btn-primary" onclick="saveUserChanges()">
                <i class="fas fa-floppy-disk"></i> Сохранить
            </button>
        </div>
    </div>
</div>

<div class="modal" id="userDetailsModal">
    <div class="modal-content">
        <div class="modal-header">
            <h3 class="modal-title">Карточка сотрудника</h3>
            <button class="modal-close" onclick="closeModal('userDetailsModal')">&times;</button>
        </div>

        <div class="modal-body" id="userDetailsBody"></div>
    </div>
</div>

<div class="modal" id="manualRequestDetailsModal">
    <div class="modal-content">
        <div class="modal-header">
            <h3 class="modal-title">Заявка на ручное время</h3>
            <button class="modal-close" onclick="closeModal('manualRequestDetailsModal')">&times;</button>
        </div>

        <div class="modal-body" id="manualRequestDetailsBody"></div>
    </div>
</div>

<div class="modal" id="manualRequestActionModal">
    <div class="modal-content">
        <div class="modal-header">
            <h3 class="modal-title" id="manualRequestActionTitle">Комментарий к заявке</h3>
            <button class="modal-close" onclick="closeModal('manualRequestActionModal')">&times;</button>
        </div>

        <div class="modal-body">
            <input type="hidden" id="manualRequestActionId" value="0">
            <input type="hidden" id="manualRequestActionType" value="">

            <div class="form-group">
                <label class="form-label" id="manualRequestActionLabel">Комментарий</label>
                <textarea class="form-control" id="manualRequestActionComment" rows="5" placeholder="Введите комментарий"></textarea>
                <div class="manual-action-hint" id="manualRequestActionHint"></div>
            </div>
        </div>

        <div class="modal-footer">
            <button class="btn btn-outline" type="button" onclick="closeModal('manualRequestActionModal')">Отмена</button>
            <button class="btn btn-primary" type="button" id="manualRequestActionSubmitBtn" onclick="submitManualRequestAction()">Сохранить</button>
        </div>
    </div>
</div>

<script>
    window.remoteControlData = {
        currentUserId: @Model.CurrentUserId,
        currentUserRole: '@Model.CurrentUserRole',
        currentUserName: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(sessionUserName)),
        currentUserEmail: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(sessionUserEmail)),
        currentUserLogin: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(sessionUserLogin)),
        isAdmin: @Model.IsAdmin.ToString().ToLower(),
        isManager: @Model.IsManager.ToString().ToLower(),
        isEmployee: false,
        users: @Html.Raw(Model.UsersJson ?? "[]"),
        tasks: @Html.Raw(Model.TasksJson ?? "[]"),
        projects: @Html.Raw(Model.ProjectsJson ?? "[]"),
        activity: @Html.Raw(Model.ActivityJson ?? "[]")
    };
</script>

@section Scripts {
    <script src="~/js/users.js" asp-append-version="true"></script>
}
