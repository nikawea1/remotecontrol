@page
@model RemoteControl1.Pages.ProjectsModel
@{
    ViewData["Title"] = "Проекты";
}

<div id="projectsPage" class="container main-content page-content">
    <div class="page-content">
        <div style="display:flex; justify-content: space-between; align-items:center; margin-bottom:30px; flex-wrap:wrap; gap:15px;">
            <h1 style="display:flex; align-items:center; gap:15px;">
                <i class="fas fa-project-diagram"></i> Проекты
            </h1>

            @if (!Model.IsEmployee)
            {
                <button class="btn btn-primary" type="button" onclick="showAddProjectModal()">
                    <i class="fas fa-plus"></i> Новый проект
                </button>
            }
        </div>

        <div class="filters-bar">
            <div class="filter-group">
                <i class="fas fa-search"></i>
                <input type="text"
                       class="filter-input"
                       style="width: 250px;"
                       placeholder="Поиск проектов..."
                       id="projectSearch"
                       onkeyup="filterProjects()">
            </div>

            <div class="filter-group">
                <i class="fas fa-sort"></i>
                <select class="filter-select" id="projectSort" onchange="sortProjects()">
                    <option value="name">По названию</option>
                    <option value="tasks">По количеству задач</option>
                    <option value="progress">По готовности</option>
                </select>
            </div>

            <div class="filter-group">
                <i class="fas fa-tag"></i>
                <select class="filter-select" id="projectStatusFilter" onchange="filterProjects()">
                    <option value="all">Все статусы</option>
                    <option value="active">Активные</option>
                    <option value="completed">Завершенные</option>
                </select>
            </div>

            <button class="btn btn-outline" type="button" onclick="resetProjectFilters()">
                <i class="fas fa-undo"></i> Сбросить
            </button>
        </div>

        <div class="projects-grid" id="projectsList"></div>
    </div>
</div>

@if (!Model.IsEmployee)
{
    <div id="addProjectModal" class="modal project-create-modal">
        <div class="modal-content project-create-content">
            <div class="modal-header project-create-header">
                <h3 class="modal-title">
                    <i class="fas fa-plus-circle"></i>
                    Новый проект
                </h3>
                <button class="modal-close" type="button" onclick="closeModal('addProjectModal')">&times;</button>
            </div>

            <div class="modal-body project-create-body">
                <div class="project-create-layout">
                    <div class="project-create-sidebar">
                        <div class="project-create-card">
                            <h3 class="detail-block-title">
                                <i class="fas fa-layer-group"></i>
                                Выбор модели проекта
                            </h3>

                            <div class="template-list" id="projectPresetList"></div>

                            <div class="helper-note">
                                Выбираешь модель проекта, а справа сразу видишь стартовый набор этапов и структуру.
                            </div>
                        </div>
                    </div>

                    <div class="project-create-main">
                        <div class="project-create-card">
                            <h3 class="detail-block-title">
                                <i class="fas fa-file-signature"></i>
                                Основные данные
                            </h3>

                            <div class="form-group">
                                <label class="form-label">Название проекта *</label>
                                <input type="text" class="form-control" id="projectName" placeholder="Введите название проекта">
                            </div>

                            <div class="form-group">
                                <label class="form-label">Описание</label>
                                <textarea class="form-control" id="projectDescription" rows="4" placeholder="Описание проекта"></textarea>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Менеджер проекта *</label>
                                <select class="form-control" id="projectManagerSelect">
                                    <option value="">Выберите менеджера</option>
                                </select>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Участники проекта</label>
                                <input type="text"
                                       class="form-control"
                                       id="projectMembersSearch"
                                       placeholder="Поиск сотрудников..."
                                       oninput="filterProjectMembersOptions('projectMembersSearch', 'projectMembersSelect')">

                                <select class="form-control" id="projectMembersSelect" multiple size="8" style="margin-top:10px;"></select>

                                <div style="font-size:12px; color: var(--gray); margin-top:8px;">
                                    Можно выбрать нескольких сотрудников
                                </div>
                            </div>
                        </div>

                        <div class="project-create-card">
                            <h3 class="detail-block-title">
                                <i class="fas fa-sitemap"></i>
                                Этапы проекта
                            </h3>

                            <div id="projectPresetStagesPreview" class="stage-editor-list"></div>

                            <div class="modal-footer" style="margin-top:18px;">
                                <button class="btn btn-outline" type="button" onclick="closeModal('addProjectModal')">Отмена</button>
                                <button class="btn btn-primary" type="button" onclick="addProject()">
                                    <i class="fas fa-save"></i> Создать проект
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<div id="editProjectModal" class="modal">
    <div class="modal-content" style="max-width: 1100px; width: 95%;">
        <div class="modal-header">
            <h3>Редактирование проекта</h3>
            <span class="close" onclick="closeModal('editProjectModal'); restoreProjectViewModal();">&times;</span>
        </div>

        <input type="hidden" id="editProjectId">

        <div style="display:grid; grid-template-columns: 320px 1fr; gap:20px;">
            <div>
                <div class="detail-block">
                    <h3 class="detail-block-title">
                        <i class="fas fa-layer-group"></i>
                        Выбор модели проекта
                    </h3>

                    <div class="template-list" id="editProjectPresetList"></div>

                    <div class="helper-note">
                        Выбираешь модель проекта, а справа видишь и редактируешь этапы.
                    </div>
                </div>
            </div>

            <div>
                <div class="detail-block">
                    <h3 class="detail-block-title">
                        <i class="fas fa-file-signature"></i>
                        Основные данные
                    </h3>

                    <div class="form-group">
                        <label class="form-label">Название проекта *</label>
                        <input type="text" class="form-control" id="editProjectName" placeholder="Введите название">
                    </div>

                    <div class="form-group">
                        <label class="form-label">Описание</label>
                        <textarea class="form-control" id="editProjectDescription" rows="3" placeholder="Описание проекта"></textarea>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Менеджер проекта *</label>
                        <select class="form-control" id="editProjectManagerSelect">
                            <option value="">Выберите менеджера</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Участники проекта</label>
                        <input type="text"
                               class="form-control"
                               id="editProjectMembersSearch"
                               placeholder="Поиск сотрудников..."
                               oninput="filterProjectMembersOptions('editProjectMembersSearch', 'editProjectMembersSelect')">

                        <select class="form-control" id="editProjectMembersSelect" multiple size="8" style="margin-top:10px;"></select>

                        <div style="font-size:12px; color: var(--gray); margin-top:8px;">
                            Можно выбрать нескольких сотрудников
                        </div>
                    </div>
                </div>

                <div class="detail-block">
                    <h3 class="detail-block-title">
                        <i class="fas fa-sitemap"></i>
                        Этапы проекта
                    </h3>

                    <div id="editProjectStagesPreview" class="stage-editor-list"></div>

                    <div class="form-group" style="margin-top:18px;">
                        <label class="form-label">Добавить этап</label>
                        <div style="display:flex; gap:10px;">
                            <input type="text" class="form-control" id="newEditStageName" placeholder="Новый этап">
                            <button class="btn btn-primary" type="button" onclick="addEditProjectStage()">
                                <i class="fas fa-plus"></i>
                            </button>
                        </div>
                    </div>

                    <div class="modal-footer" style="margin-top:18px;">
                        <button class="btn btn-outline" type="button" onclick="closeModal('editProjectModal'); restoreProjectViewModal();">Отмена</button>
                        <button class="btn btn-primary" type="button" onclick="saveProjectChanges()">
                            <i class="fas fa-save"></i> Сохранить
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="deleteProjectModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3>Удаление проекта</h3>
            <span class="close" onclick="closeModal('deleteProjectModal')">&times;</span>
        </div>

        <input type="hidden" id="deleteProjectId">

        <div style="margin-bottom: 18px; line-height: 1.6;">
            Вы действительно хотите удалить проект
            <strong id="deleteProjectName"></strong>?
        </div>

        <div style="background: rgba(255, 99, 132, 0.08); border: 1px solid rgba(255, 99, 132, 0.25); border-radius: 12px; padding: 14px 16px; margin-bottom: 20px;">
            <div style="display:flex; align-items:center; gap:10px; margin-bottom:8px; color:#d9534f; font-weight:600;">
                <i class="fas fa-exclamation-triangle"></i>
                <span>Внимание</span>
            </div>
            <div style="color: var(--gray-dark); font-size: 14px; line-height: 1.5;">
                Вместе с проектом будут удалены все связанные задачи:
                <strong><span id="deleteProjectTasksCount">0</span></strong>.
                Это действие нельзя отменить.
            </div>
        </div>

        <div class="modal-footer">
            <button class="btn btn-outline" type="button" onclick="closeModal('deleteProjectModal')">Отмена</button>
            <button class="btn btn-danger" type="button" onclick="confirmDeleteProject()">
                <i class="fas fa-trash"></i> Удалить проект
            </button>
        </div>
    </div>
</div>

<div id="editTaskModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3>Редактирование задачи</h3>
            <span class="close" onclick="closeModal('editTaskModal'); restoreProjectViewAfterTaskModal();">&times;</span>
        </div>

        <input type="hidden" id="editTaskId">

        <div class="form-group">
            <label class="form-label">Название задачи *</label>
            <input type="text" class="form-control" id="editTaskName">
        </div>

        <div class="form-group">
            <label class="form-label">Описание</label>
            <textarea class="form-control" id="editTaskDescription" rows="3"></textarea>
        </div>

        <div class="form-group">
            <label class="form-label">Проект</label>
            <select class="form-control" id="editTaskProject"></select>
        </div>

        <div class="form-group">
            <label class="form-label">Этап проекта</label>
            <select class="form-control" id="editTaskStageSelect">
                <option value="">Выберите этап</option>
            </select>
        </div>

        <div class="form-group">
            <label class="form-label">Исполнитель</label>
            <select class="form-control" id="editTaskAssignee"></select>
        </div>

        <div class="form-group">
            <label class="form-label">Приоритет</label>
            <select class="form-control" id="editTaskPriority">
                <option value="high">Высокий</option>
                <option value="medium">Средний</option>
                <option value="low">Низкий</option>
            </select>
        </div>

        <div class="form-group">
            <label class="form-label">Статус</label>
            <select class="form-control" id="editTaskStatus">
                <option value="new">Новая</option>
                <option value="progress">В работе</option>
                <option value="review">На проверке</option>
                <option value="done">Завершена</option>
            </select>
        </div>

        <div class="form-group">
            <label class="form-label">Плановое время (часы)</label>
            <input type="number" class="form-control" id="editTaskPlannedTime" step="0.5" min="0">
        </div>

        <div class="form-group">
            <label class="form-label">Дедлайн</label>
            <input type="date" class="form-control" id="editTaskDeadline">
        </div>

        <button class="btn btn-primary" type="button" style="width: 100%;" onclick="saveTaskChanges()">
            <i class="fas fa-save"></i> Сохранить изменения
        </button>
    </div>
</div>

<div id="deleteTaskModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3>Подтверждение удаления</h3>
            <span class="close" onclick="closeModal('deleteTaskModal'); restoreProjectViewAfterTaskModal();">&times;</span>
        </div>

        <input type="hidden" id="deleteTaskId">

        <p style="margin-bottom:20px;">
            Вы действительно хотите удалить задачу
            <strong id="deleteTaskName"></strong>?
        </p>

        <div class="modal-footer">
            <button class="btn btn-outline" type="button" onclick="closeModal('deleteTaskModal'); restoreProjectViewAfterTaskModal();">Отмена</button>
            <button class="btn btn-danger" type="button" onclick="confirmDeleteTask()">
                <i class="fas fa-trash"></i> Удалить
            </button>
        </div>
    </div>
</div>

<div id="projectViewOverlay" class="project-view-overlay" onclick="closeProjectViewModal()"></div>

<div id="projectViewModal" class="project-view-shell">
    <div class="project-view-frame">
        <div class="project-view-head">
            <h2 class="project-view-title">
                <i class="fas fa-folder-open"></i>
                <span id="projectViewModalTitle">Просмотр проекта</span>
            </h2>

            <button class="project-view-close" type="button" onclick="closeProjectViewModal()">
                &times;
            </button>
        </div>

        <div id="projectViewModalContent" class="project-view-scroll"></div>
    </div>
</div>

<script>
    window.remoteControlData = window.remoteControlData || {};
    Object.assign(window.remoteControlData, {
        currentUserId: @Model.CurrentUserId,
        currentUserRole: '@Model.CurrentUserRole',
        isAdmin: @Model.IsAdmin.ToString().ToLower(),
        isManager: @Model.IsManager.ToString().ToLower(),
        isEmployee: @Model.IsEmployee.ToString().ToLower(),
        projects: @Html.Raw(Model.ProjectsJson ?? "[]"),
        tasks: @Html.Raw(Model.TasksJson ?? "[]"),
        users: @Html.Raw(Model.UsersJson ?? "[]")
    });
</script>

@section Scripts {
    <script src="~/js/tasks.js" asp-append-version="true"></script>
    <script src="~/js/projects.js" asp-append-version="true"></script>
}