                                    <div class="stat-value" id="profileDoneTasks">0</div>
                                    <div class="stat-label">Выполнено задач</div>
                                </div>
                            </div>

                            <div class="stat-card">
                                <div class="stat-icon"><i class="fas fa-clock"></i></div>
                                <div class="stat-info">
                                    <div class="stat-value" id="profileHours">0</div>
                                    <div class="stat-label">Часов отработано</div>
                                </div>
                            </div>

                            <div class="stat-card">
                                <div class="stat-icon"><i class="fas fa-folder-open"></i></div>
                                <div class="stat-info">
                                    <div class="stat-value" id="profileProjectsCount">0</div>
                                    <div class="stat-label">Проектов</div>
                                </div>
                            </div>
                        </div>

                        <div class="card">
                            <div class="card-header">
                                <h3 class="card-title"><i class="fas fa-history"></i> Последняя активность</h3>
                            </div>

                            <div class="table-container">
                                <table class="table">
                                    <thead>
                                        <tr>
                                            <th>Дата</th>
                                            <th>Задача</th>
                                            <th>Часы</th>
                                            <th>Комментарий</th>
                                        </tr>
                                    </thead>
                                    <tbody id="profileActivityBody"></tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <div id="profileSecurity" class="admin-tab-content hidden">
                        <div class="card">
                            <div class="card-header">
                                <h3 class="card-title"><i class="fas fa-lock"></i> Безопасность</h3>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Текущий пароль</label>
                                <input type="password" class="form-control" id="profileCurrentPassword" placeholder="Введите текущий пароль">
                            </div>

                            <div class="form-row">
                                <div class="form-group">
                                    <label class="form-label">Новый пароль</label>
                                    <input type="password" class="form-control" id="profileNewPassword" placeholder="Введите новый пароль">
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Подтверждение</label>
                                    <input type="password" class="form-control" id="profileConfirmPassword" placeholder="Повторите пароль">
                                </div>
                            </div>

                            <div class="modal-footer" style="margin-top:0;">
                                <button class="btn btn-primary" type="button" onclick="changePassword()">
                                    <i class="fas fa-key"></i> Сменить пароль
                                </button>
                            </div>
                        </div>
                    </div>

                    <div id="profilePrefs" class="admin-tab-content hidden">
                        <div class="card">
                            <div class="card-header">
                                <h3 class="card-title"><i class="fas fa-cog"></i> Пользовательские настройки</h3>
                            </div>

                            <div class="settings-grid">
                                <div class="setting-item">
                                    <label class="form-label">Уведомления в интерфейсе</label>
                                    <div class="form-check">
                                        <input type="checkbox" class="form-check-input" id="profileNotifyUi">
                                        <label class="form-check-label" for="profileNotifyUi">Показывать уведомления</label>
                                    </div>
                                </div>

                                <div class="setting-item">
                                    <label class="form-label">Автовыбор последней задачи</label>
                                    <div class="form-check">
                                        <input type="checkbox" class="form-check-input" id="profileRememberTask">
                                        <label class="form-check-label" for="profileRememberTask">Запоминать последнюю задачу</label>
                                    </div>
                                </div>

                                <div class="setting-item">
                                    <label class="form-label">Снимки экрана</label>
                                    <div class="form-check">
                                        <input type="checkbox" class="form-check-input" id="profileUseScreens">
                                        <label class="form-check-label" for="profileUseScreens">Разрешить снимки экрана</label>
                                    </div>
                                </div>

                                <div class="setting-item">
                                    <label class="form-label">Снимки веб-камеры</label>
                                    <div class="form-check">
                                        <input type="checkbox" class="form-check-input" id="profileUseWebcam">
                                        <label class="form-check-label" for="profileUseWebcam">Разрешить снимки веб-камеры</label>
                                    </div>
                                </div>
                            </div>

                            <div class="form-group" style="margin-top:20px;">
                                <label class="form-label">Личная заметка</label>
                                <textarea class="form-control" id="profilePersonalNote" rows="4" placeholder="Любая личная заметка по работе"></textarea>
                            </div>

                            <div class="modal-footer">
                                <button class="btn btn-outline" type="button" onclick="resetProfilePreferences()">
                                    Сбросить
                                </button>
                            </div>
                        </div>

                    </div>
                    <div class="card">
                        <div class="modal-footer" style="margin-top:0; justify-content:flex-end;">
                            <button class="btn btn-primary" type="button" onclick="saveProfile()">
                                <i class="fas fa-save"></i> Сохранить изменения
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="bottom-tracker" id="bottomTracker">
        <div class="bottom-tracker-time" id="bottomTimer">00:00:00</div>
        <div class="bottom-tracker-controls">
            <button class="btn btn-success bottom-tracker-btn" onclick="startTracking()" id="bottomStartBtn" title="Старт"><i class="fas fa-play"></i></button>
            <button class="btn btn-warning bottom-tracker-btn" onclick="pauseTracking()" id="bottomPauseBtn" title="Пауза"><i class="fas fa-pause"></i></button>
            <button class="btn btn-danger bottom-tracker-btn" onclick="stopTracking()" id="bottomStopBtn" title="Стоп"><i class="fas fa-stop"></i></button>
        </div>
        <div class="bottom-tracker-status" id="bottomStatus">
            <span class="status-dot stopped" id="statusDot"></span>
            <span id="statusText">Остановлен</span>
        </div>
    </div>

    <div id="addTaskModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Новая задача</h3>
                <span class="close" onclick="closeModal('addTaskModal')">&times;</span>
            </div>

            <div class="form-group">
                <label class="form-label">Название задачи *</label>
                <input type="text" class="form-control" id="taskName" placeholder="Введите название">
            </div>

            <div class="form-group">
                <label class="form-label">Описание</label>
                <textarea class="form-control" id="taskDescription" rows="3" placeholder="Описание задачи"></textarea>
            </div>

            <div class="form-group">
                <label class="form-label">Проект</label>
                <select class="form-control" id="taskProjectSelect"></select>
            </div>

            <div class="form-group">
                <label class="form-label">Этап проекта</label>
                <select class="form-control" id="taskStageSelect">
                    <option value="">Выберите этап</option>
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">Исполнитель</label>
                <select class="form-control" id="taskAssignee">
                    <option value="">Выберите исполнителя</option>
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">Приоритет</label>
                <select class="form-control" id="taskPriority">
                    <option value="high">Высокий</option>
                    <option value="medium" selected>Средний</option>
                    <option value="low">Низкий</option>
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">Плановое время (часы)</label>
                <input type="number" class="form-control" id="taskPlannedTime" step="0.5" min="0.5" value="8">
            </div>

            <div class="form-group">
                <label class="form-label">Дедлайн</label>
                <input type="date" class="form-control" id="taskDeadline">
            </div>

            <button class="btn btn-primary" style="width: 100%;" onclick="addTask()">
                <i class="fas fa-save"></i> Сохранить задачу
            </button>
        </div>
    </div>

    <div id="addProjectModal" class="modal project-create-modal">
        <div class="modal-content project-create-content">
            <div class="modal-header project-create-header">
                <h3 class="modal-title">
                    <i class="fas fa-plus-circle"></i>
                    Новый проект
                </h3>
                <button class="modal-close" type="button" onclick="closeModal('addProjectModal')">&times;</button>
            </div>

            <div class="modal-body project-create-body">
                <div class="project-create-layout">
                    <div class="project-create-sidebar">
                        <div class="project-create-card">
                            <h3 class="detail-block-title">
                                <i class="fas fa-layer-group"></i>
                                Выбор модели проекта
                            </h3>

                            <div class="template-list" id="projectPresetList"></div>

                            <div class="helper-note">
                                Выбираешь модель проекта, а справа сразу видишь стартовый набор этапов и структуру.
                            </div>
                        </div>
                    </div>

                    <div class="project-create-main">
                        <div class="project-create-card">
                            <h3 class="detail-block-title">
                                <i class="fas fa-file-signature"></i>
                                Основные данные
                            </h3>

                            <div class="form-group">
                                <label class="form-label">Название проекта *</label>
                                <input type="text" class="form-control" id="projectName" placeholder="Введите название проекта">
                            </div>

                            <div class="form-group">
                                <label class="form-label">Описание</label>
                                <textarea class="form-control" id="projectDescription" rows="4" placeholder="Описание проекта"></textarea>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Менеджер проекта *</label>
                                <select class="form-control" id="projectManagerSelect">
                                    <option value="">Выберите менеджера</option>
                                </select>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Участники проекта</label>
                                <input type="text"
                                       class="form-control"
                                       id="projectMembersSearch"
                                       placeholder="Поиск сотрудников..."
                                       oninput="filterProjectMembersOptions('projectMembersSearch', 'projectMembersSelect')"
                                       style="margin-bottom:10px;">

                                <select class="form-control" id="projectMembersSelect" multiple size="8"></select>

                                <div style="font-size:12px; color: var(--gray); margin-top:8px;">
                                    Можно выбрать нескольких сотрудников
                                </div>
                            </div>
                        </div>

                        <div class="project-create-card">
                            <h3 class="detail-block-title">
                                <i class="fas fa-sitemap"></i>
                                Этапы будущего проекта
                            </h3>

                            <div class="stage-editor-list" id="projectPresetStagesPreview"></div>

                            <div class="helper-note">
                                Сейчас это пресетный набор этапов. Дальше подключим сохранение этапов в базу.
                            </div>

                            <div class="modal-footer" style="margin-top:18px;">
                                <button class="btn btn-outline" type="button" onclick="closeModal('addProjectModal')">Отмена</button>
                                <button class="btn btn-primary" type="button" onclick="addProject()">
                                    <i class="fas fa-save"></i> Создать проект
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div id="editProjectModal" class="modal">
        <div class="modal-content" style="max-width: 1100px; width: 95%;">
            <div class="modal-header">
                <h3>Редактирование проекта</h3>
                <span class="close" onclick="closeModal('editProjectModal'); restoreProjectViewModal();">&times;</span>
            </div>

            <input type="hidden" id="editProjectId">

            <div style="display:grid; grid-template-columns: 320px 1fr; gap:20px;">
                <div>
                    <div class="detail-block">
                        <h3 class="detail-block-title">
                            <i class="fas fa-layer-group"></i>
                            Выбор модели проекта
                        </h3>

                        <div class="template-list" id="editProjectPresetList"></div>

                        <div class="helper-note">
                            Выбираешь модель проекта, а справа видишь и редактируешь этапы.
                        </div>
                    </div>
                </div>

                <div>
                    <div class="detail-block">
                        <h3 class="detail-block-title">
                            <i class="fas fa-file-signature"></i>
                            Основные данные
                        </h3>

                        <div class="form-group">
                            <label class="form-label">Название проекта *</label>
                            <input type="text" class="form-control" id="editProjectName" placeholder="Введите название">
                        </div>

                        <div class="form-group">
                            <label class="form-label">Описание</label>
                            <textarea class="form-control" id="editProjectDescription" rows="3" placeholder="Описание проекта"></textarea>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Менеджер проекта *</label>
                            <select class="form-control" id="editProjectManagerSelect">
                                <option value="">Выберите менеджера</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Участники проекта</label>
                            <input type="text"
                                   class="form-control"
                                   id="editProjectMembersSearch"
                                   placeholder="Поиск сотрудников..."
                                   oninput="filterProjectMembersOptions('editProjectMembersSearch', 'editProjectMembersSelect')">

                            <select class="form-control" id="editProjectMembersSelect" multiple size="8" style="margin-top:10px;"></select>

                            <div style="font-size:12px; color: var(--gray); margin-top:8px;">
                                Можно выбрать нескольких сотрудников
                            </div>
                        </div>
                    </div>

                    <div class="detail-block">
                        <h3 class="detail-block-title">
                            <i class="fas fa-sitemap"></i>
                            Этапы проекта
                        </h3>

                        <div class="stage-editor-list" id="editProjectStagesList"></div>

                        <div style="display:flex; gap:10px; margin-top:14px; flex-wrap:wrap;">
                            <input type="text"
                                   class="form-control"
                                   id="newEditStageName"
                                   placeholder="Новый этап"
                                   style="flex:1; min-width:220px;">

                            <button class="btn btn-outline" type="button" onclick="addEditProjectStage()">
                                <i class="fas fa-plus"></i> Добавить этап
                            </button>
                        </div>

                        <div class="helper-note">
                            Можно менять порядок этапов, переименовывать и удалять их до сохранения проекта.
                        </div>

                        <div class="modal-footer" style="margin-top:18px;">
                            <button class="btn btn-outline" type="button" onclick="closeModal('editProjectModal'); restoreProjectViewModal();">Отмена</button>
                            <button class="btn btn-primary" type="button" onclick="saveProjectChanges()">
                                <i class="fas fa-save"></i> Сохранить
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div id="deleteProjectModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Удаление проекта</h3>
                <span class="close" onclick="closeModal('deleteProjectModal')">&times;</span>
            </div>

            <input type="hidden" id="deleteProjectId">

            <div style="margin-bottom: 18px; line-height: 1.6;">
                Вы действительно хотите удалить проект
                <strong id="deleteProjectName"></strong>?
            </div>

            <div style="background: rgba(255, 99, 132, 0.08); border: 1px solid rgba(255, 99, 132, 0.25); border-radius: 12px; padding: 14px 16px; margin-bottom: 20px;">
                <div style="display:flex; align-items:center; gap:10px; margin-bottom:8px; color:#d9534f; font-weight:600;">
                    <i class="fas fa-exclamation-triangle"></i>
                    <span>Внимание</span>
                </div>
                <div style="color: var(--gray-dark); font-size: 14px; line-height: 1.5;">
                    Вместе с проектом будут удалены все связанные задачи:
                    <strong><span id="deleteProjectTasksCount">0</span></strong>.
                    Это действие нельзя отменить.
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-outline" onclick="closeModal('deleteProjectModal')">Отмена</button>
                <button class="btn btn-danger" onclick="confirmDeleteProject()">
                    <i class="fas fa-trash"></i> Удалить проект
                </button>
            </div>
        </div>
    </div>
    <div id="editTaskModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Редактирование задачи</h3>
                <span class="close" onclick="closeModal('editTaskModal'); restoreProjectViewAfterTaskModal();">&times;</span>
            </div>

            <input type="hidden" id="editTaskId">

            <div class="form-group">
                <label class="form-label">Название задачи *</label>
                <input type="text" class="form-control" id="editTaskName">
            </div>

            <div class="form-group">
                <label class="form-label">Описание</label>
                <textarea class="form-control" id="editTaskDescription" rows="3"></textarea>
            </div>

            <div class="form-group">
                <label class="form-label">Проект</label>
                <select class="form-control" id="editTaskProject"></select>
            </div>

            <div class="form-group">
                <label class="form-label">Этап проекта</label>
                <select class="form-control" id="editTaskStageSelect">
                    <option value="">Выберите этап</option>
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">Исполнитель</label>
                <select class="form-control" id="editTaskAssignee"></select>
            </div>

            <div class="form-group">
                <label class="form-label">Приоритет</label>
                <select class="form-control" id="editTaskPriority">
                    <option value="high">Высокий</option>
                    <option value="medium">Средний</option>
                    <option value="low">Низкий</option>
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">Статус</label>
                <select class="form-control" id="editTaskStatus">
                    <option value="new">Новая</option>
                    <option value="progress">В работе</option>
                    <option value="review">На проверке</option>
                    <option value="done">Завершена</option>
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">Плановое время (часы)</label>
                <input type="number" class="form-control" id="editTaskPlannedTime" step="0.5" min="0">
            </div>

            <div class="form-group">
                <label class="form-label">Дедлайн</label>
                <input type="date" class="form-control" id="editTaskDeadline">
            </div>

            <button class="btn btn-primary" style="width: 100%;" onclick="saveTaskChanges()">
                <i class="fas fa-save"></i> Сохранить изменения
            </button>
        </div>
    </div>

    <div id="deleteTaskModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Подтверждение удаления</h3>
                <span class="close" onclick="closeModal('deleteTaskModal'); restoreProjectViewAfterTaskModal();">&times;</span>
            </div>

            <input type="hidden" id="deleteTaskId">

            <p style="margin-bottom:20px;">
                Вы действительно хотите удалить задачу
                <strong id="deleteTaskName"></strong>?
            </p>

            <div class="modal-footer">
                <button class="btn btn-outline" onclick="closeModal('deleteTaskModal'); restoreProjectViewAfterTaskModal();">Отмена</button>
                <button class="btn btn-danger" onclick="confirmDeleteTask()">
                    <i class="fas fa-trash"></i> Удалить
                </button>
            </div>
        </div>
    </div>

    <div id="notification" class="notification hidden">
        <div style="display:flex; align-items:center; gap:10px;">
            <i class="fas fa-info-circle" style="color: var(--primary); font-size: 20px;"></i>
            <div id="notificationMessage">Уведомление</div>
        </div>
    </div>


    <div id="projectViewOverlay" class="project-view-overlay" onclick="closeProjectViewModal()"></div>

    <div id="projectViewModal" class="project-view-shell">
        <div class="project-view-frame">
            <div class="project-view-head">
                <h2 class="project-view-title">
                    <i class="fas fa-folder-open"></i>
                    <span id="projectViewModalTitle">Просмотр проекта</span>
                </h2>

                <button class="project-view-close" type="button" onclick="closeProjectViewModal()">
                    &times;
                </button>
            </div>

            <div id="projectViewModalContent" class="project-view-scroll"></div>
        </div>
    </div>


    <script>
        window.remoteControlData = {
            currentUserName: '@Html.Raw((Model.UserName ?? "").Replace("'", "\\'"))',
            currentUserEmail: '@Html.Raw((Model.UserEmail ?? "").Replace("'", "\\'"))',
            currentUserLogin: '@Html.Raw((Model.CurrentUserLogin ?? "").Replace("'", "\\'"))',
            currentUserPhone: '@Html.Raw((Model.CurrentUserPhone ?? "").Replace("'", "\\'"))',
            currentUserPosition: '@Html.Raw((Model.CurrentUserPosition ?? "").Replace("'", "\\'"))',
            currentUserRate: @Model.CurrentUserRate.ToString(System.Globalization.CultureInfo.InvariantCulture),
            currentUserIsActive: @Model.CurrentUserIsActive.ToString().ToLower(),
            currentUserId: @Model.CurrentUserId,
            currentUserRole: '@Model.CurrentUserRole',
            isAdmin: @Model.IsAdmin.ToString().ToLower(),
            isManager: @Model.IsManager.ToString().ToLower(),
            isEmployee: @Model.IsEmployee.ToString().ToLower(),
            tasks: @Html.Raw(Model.TasksJson ?? "[]"),
            projects: @Html.Raw(Model.ProjectsJson ?? "[]"),
            activity: @Html.Raw(Model.ActivityJson ?? "[]"),
            users: @Html.Raw(Model.UsersJson ?? "[]"),
            workDays: @Html.Raw(Model.WorkDaysJson ?? "[]")
        };
    </script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/tasks.js" asp-append-version="true"></script>
    <script src="~/js/projects.js" asp-append-version="true"></script>
    <script src="~/js/users.js" asp-append-version="true"></script>
    <script src="~/js/reports.js" asp-append-version="true"></script>
    <script src="~/js/timer.js" asp-append-version="true"></script>
    <script src="~/js/capture.js" asp-append-version="true"></script>
</body>
</html>