@page
@model RemoteControl1.Pages.MainPageModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Remote Control</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true">
</head>

<body>
    @Html.AntiForgeryToken()

    <nav class="navbar">
        <div class="container nav-container">
            <div class="nav-logo">
                <i class="fas fa-clock"></i>
                REMOTE CONTROL
            </div>

            <ul class="nav-menu">
                <li><a class="nav-link active" onclick="showPage('dashboard')"><i class="fas fa-home"></i>Главная</a></li>
                <li><a class="nav-link" onclick="showPage('tasks')"><i class="fas fa-tasks"></i>Задачи</a></li>
                <li><a class="nav-link" onclick="showPage('projects')"><i class="fas fa-project-diagram"></i>Проекты</a></li>
                <li><a class="nav-link" onclick="showPage('tracker')"><i class="fas fa-stopwatch"></i>Трекер</a></li>
                <li><a class="nav-link" onclick="showPage('reports')"><i class="fas fa-chart-bar"></i>Отчеты</a></li>
                @if (!Model.IsEmployee)
                {
                    <li><a class="nav-link" onclick="showPage('users')"><i class="fas fa-users"></i>Сотрудники</a></li>
                }
            </ul>

            <div style="display:flex; align-items:center; gap:15px; position: relative;">
                <div style="font-weight: 500;" id="userNameHeader">@Model.UserName</div>
                <div style="width: 42px; height: 42px; background: var(--primary); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 600; cursor: pointer;"
                     onclick="toggleProfileDropdown()" id="userAvatar">
                    @((Model.UserName ?? "U").Trim().Length > 0 ? (Model.UserName.Trim()[0]).ToString().ToUpper() : "U")
                </div>

                <div class="profile-dropdown" id="profileDropdown">
                    <div class="profile-dropdown-header">
                        <div class="profile-dropdown-avatar" id="dropdownAvatar">Н</div>
                        <div class="profile-dropdown-info">
                            <h4 id="dropdownName">@Model.UserName</h4>
                            <p id="dropdownRole">Сотрудник</p>
                            <p style="margin-top:6px; font-size:13px; color: rgba(255,255,255,0.85);" id="dropdownEmail">@Model.UserEmail</p>
                        </div>
                    </div>
                    <div class="profile-dropdown-menu">
                        <div class="profile-dropdown-item" onclick="showPage('profile')">
                            <i class="fas fa-user"></i>
                            <span>Мой профиль</span>
                        </div>
                        <div class="profile-dropdown-divider"></div>
                        <div class="profile-dropdown-item" onclick="logout()">
                            <i class="fas fa-sign-out-alt"></i>
                            <span>Выйти</span>
                        </div>
                    </div>
                    <div class="profile-dropdown-footer">
                        <span><i class="far fa-clock"></i> Последний вход: сегодня 09:00</span>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <div class="container main-content">
        <div id="dashboardPage" class="page-content">
            <div style="display:flex; justify-content: space-between; align-items:center; margin-bottom:30px;">
                <h1 style="display:flex; align-items:center; gap:15px;">
                    <i class="fas fa-tachometer-alt"></i> Главная панель
                </h1>
                <div>
                    <button class="btn btn-success" onclick="startTracker()" id="startDayBtn">
                        <i class="fas fa-play"></i> Начать рабочий день
                    </button>
                    <button class="btn btn-danger hidden" onclick="stopTracker()" id="stopDayBtn">
                        <i class="fas fa-stop"></i> Завершить рабочий день
                    </button>
                </div>
            </div>

            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-clock"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" id="totalHours">0.0</div>
                        <div class="stat-label">Отработано часов</div>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-tasks"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" id="activeTasks">0</div>
                        <div class="stat-label">Активных задач</div>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-project-diagram"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" id="activeProjects">0</div>
                        <div class="stat-label">Активных проектов</div>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-calendar-check"></i></div>
                    <div class="stat-info">
                        <div class="stat-value" id="completedTasks">0</div>
                        <div class="stat-label">Выполненных задач</div>
                    </div>
                </div>
            </div>

            <div class="tracker-box">
                <h2 style="margin-bottom: 10px;"><i class="fas fa-stopwatch"></i> Трекер времени</h2>
                <div class="form-group" style="max-width: 300px; margin: 0 auto;">
                    <select class="form-control" id="currentTask">
                        <option value="">Выберите задачу</option>
                    </select>
                </div>

                <div class="timer" id="timer">00:00:00</div>

                <div style="display:flex; justify-content:center; gap:15px; margin-top:20px;">
                    <button class="btn tracker-btn tracker-btn-success" onclick="startTracking()" id="startBtn">
                        <i class="fas fa-play"></i> Старт
                    </button>
                    <button class="btn tracker-btn tracker-btn-warning" onclick="pauseTracking()" id="pauseBtn">
                        <i class="fas fa-pause"></i> Пауза
                    </button>
                    <button class="btn tracker-btn tracker-btn-danger" onclick="stopTracking()" id="stopBtn">
                        <i class="fas fa-stop"></i> Стоп
                    </button>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Мои задачи на сегодня</h3>
                    <button class="btn btn-outline" onclick="showPage('tasks')"><i class="fas fa-eye"></i> Все задачи</button>
                </div>

                <div class="tasks-grid" id="dashboardTasks"></div>
            </div>

            <div class="card">
                <div class="card-header"><h3 class="card-title">Быстрый учет времени</h3></div>

                <div class="form-row" style="align-items: flex-end;">
                    <div class="form-group" style="flex: 2;">
                        <label class="form-label">Задача</label>
                        <select class="form-control" id="quickTask"></select>
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Часы</label>
                        <input type="number" class="form-control" id="quickHours" step="0.5" min="0.5" value="1">
                    </div>
                    <div class="form-group" style="flex: 2;">
                        <label class="form-label">Комментарий</label>
                        <input type="text" class="form-control" id="quickComment" placeholder="Что сделано?">
                    </div>
                    <div class="form-group" style="flex: 2;">
                        <label class="form-label">Файл-пруф</label>
                        <input type="file" class="form-control" id="quickAttachment">
                    </div>
                    <div class="form-group">
                        <button class="btn btn-primary" onclick="addTimeEntry()" style="height: 42px;">
                            <i class="fas fa-plus"></i> Добавить
                        </button>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header"><h3 class="card-title">Последняя активность</h3></div>

                <div class="table-container">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Дата</th>
                                <th>Задача</th>
                                <th>Время</th>
                                <th>Комментарий</th>
                                <th>Файл</th>
                                <th>Статус</th>
                            </tr>
                        </thead>
                        <tbody id="activityLog"></tbody>
                    </table>
                </div>
            </div>
        </div>

        <div id="tasksPage" class="page-content hidden">
            <div style="display:flex; justify-content: space-between; align-items:center; margin-bottom:30px;">
                <h1 style="display:flex; align-items:center; gap:15px;"><i class="fas fa-tasks"></i> Управление задачами</h1>
                @if (!Model.IsEmployee)
                {
                    <button class="btn btn-primary" onclick="showAddTaskModal()"><i class="fas fa-plus"></i> Новая задача</button>
                }
            </div>

            <div class="filters-bar">
                <div class="filter-group">
                    <i class="fas fa-filter"></i>
                    <select class="filter-select" id="taskStatusFilter" onchange="filterTasks()">
                        <option value="all">Все статусы</option>
                        <option value="new">Новые</option>
                        <option value="progress">В работе</option>
                        <option value="review">На проверке</option>
                        <option value="done">Завершено</option>
                    </select>
                </div>

                <div class="filter-group">
                    <i class="fas fa-flag"></i>
                    <select class="filter-select" id="taskPriorityFilter" onchange="filterTasks()">
                        <option value="all">Все приоритеты</option>
                        <option value="high">Высокий</option>
                        <option value="medium">Средний</option>
                        <option value="low">Низкий</option>
                    </select>
                </div>

                <div class="filter-group">
                    <i class="fas fa-project-diagram"></i>
                    <select class="filter-select" id="taskProjectFilter" onchange="filterTasks()">
                        <option value="all">Все проекты</option>
                    </select>
                </div>

                <div class="filter-group">
                    <i class="fas fa-search"></i>
                    <input type="text" class="filter-input" id="taskSearch" placeholder="Поиск по названию..." onkeyup="filterTasks()">
                </div>
            </div>

            <div class="card">
                <div class="table-container">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Название задачи</th>
                                <th>Проект</th>
                                <th>Этап</th>
                                <th>Приоритет</th>
                                <th>Срок</th>
                                <th>Статус</th>
                                <th>Исполнитель</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody id="tasksTable"></tbody>
                    </table>
                </div>
            </div>
        </div>

        <div id="projectsPage" class="page-content hidden">
            <div style="display:flex; justify-content: space-between; align-items:center; margin-bottom:30px;">
                <h1 style="display:flex; align-items:center; gap:15px;"><i class="fas fa-project-diagram"></i> Проекты</h1>
                @if (!Model.IsEmployee)
                {
                    <button class="btn btn-primary" onclick="showAddProjectModal()"><i class="fas fa-plus"></i> Новый проект</button>
                }
            </div>

            <div class="filters-bar">
                <div class="filter-group">
                    <i class="fas fa-search"></i>
                    <input type="text" class="filter-input" style="width: 250px;" placeholder="Поиск проектов..." id="projectSearch" onkeyup="filterProjects()">
                </div>

                <div class="filter-group">
                    <i class="fas fa-sort"></i>
                    <select class="filter-select" id="projectSort" onchange="sortProjects()">
                        <option value="name">По названию</option>
                        <option value="tasks">По количеству задач</option>
                        <option value="progress">По готовности</option>
                    </select>
                </div>

                <div class="filter-group">
                    <i class="fas fa-tag"></i>
                    <select class="filter-select" id="projectStatusFilter" onchange="filterProjects()">
                        <option value="all">Все статусы</option>
                        <option value="active">Активные</option>
                        <option value="completed">Завершенные</option>
                    </select>
                </div>

                <button class="btn btn-outline" type="button" onclick="resetProjectFilters()">
                    <i class="fas fa-undo"></i> Сбросить
                </button>
            </div>

            <div class="projects-grid" id="projectsList"></div>
        </div>

        <div id="trackerPage" class="page-content hidden">
            <div style="display:flex; justify-content: space-between; align-items:center; margin-bottom:30px;">
                <h1 style="display:flex; align-items:center; gap:15px;"><i class="fas fa-stopwatch"></i> Трекер времени</h1>
            </div>

            <div class="tracker-box">
                <h2 style="margin-bottom: 10px;">Текущая сессия</h2>

                <div class="form-group" style="max-width: 300px; margin: 0 auto;">
                    <select class="form-control" id="currentTaskFull">
                        <option value="">Выберите задачу</option>
                    </select>
                </div>

                <div class="timer" id="timerFull">00:00:00</div>

                <div style="display:flex; justify-content:center; gap:15px; margin-top:20px;">
                    <button class="btn tracker-btn tracker-btn-success" onclick="startTracking()"><i class="fas fa-play"></i> Старт</button>
                    <button class="btn tracker-btn tracker-btn-warning" onclick="pauseTracking()"><i class="fas fa-pause"></i> Пауза</button>
                    <button class="btn tracker-btn tracker-btn-danger" onclick="stopTracking()"><i class="fas fa-stop"></i> Стоп</button>
                </div>
            </div>

            <div class="card">
                <div class="card-header"><h3 class="card-title">Настройки трекера</h3></div>

                <div class="settings-grid">
                    <div class="setting-item">
                        <label class="form-label">Интервал снимков экрана</label>
                        <input type="range" id="screenInterval" min="5" max="60" value="10" step="5" style="width: 100%;" oninput="updateRangeValue(this, 'screenIntervalValue')">
                        <div style="display:flex; justify-content: space-between; margin-top:5px;">
                            <span style="font-size:12px;">5 сек</span>
                            <span class="range-value" id="screenIntervalValue">10 сек</span>
                            <span style="font-size:12px;">60 сек</span>
                        </div>
                    </div>

                    <div class="setting-item">
                        <label class="form-label">Интервал снимков веб-камеры</label>
                        <input type="range" id="webcamInterval" min="5" max="60" value="10" step="5" style="width: 100%;" oninput="updateRangeValue(this, 'webcamIntervalValue')">
                        <div style="display:flex; justify-content: space-between; margin-top:5px;">
                            <span style="font-size:12px;">5 сек</span>
                            <span class="range-value" id="webcamIntervalValue">10 сек</span>
                            <span style="font-size:12px;">60 сек</span>
                        </div>
                    </div>

                    <div class="setting-item">
                        <label class="form-label">Таймаут простоя</label>
                        <input type="range" id="idleTimeout" min="1" max="10" value="3" step="1" style="width: 100%;" oninput="updateRangeValue(this, 'timeoutIntervalValue')">
                        <div style="display:flex; justify-content: space-between; margin-top:5px;">
                            <span style="font-size:12px;">1 мин</span>
                            <span class="range-value" id="timeoutIntervalValue">3 мин</span>
                            <span style="font-size:12px;">10 мин</span>
                        </div>
                    </div>

                    <div class="setting-item">
                        <label class="form-label">Опции</label>

                        <div class="form-check" style="margin-bottom: 12px;">
                            <input type="checkbox" class="form-check-input" id="enableScreenShots" checked>
                            <label class="form-check-label" for="enableScreenShots">Делать снимки экрана</label>
                        </div>

                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="enableWebcamShots" checked>
                            <label class="form-check-label" for="enableWebcamShots">Делать снимки веб-камеры</label>
                        </div>
                    </div>
                </div>

                <div style="display:flex; gap:10px; justify-content:flex-end; margin-top:20px;">
                    <button class="btn btn-outline" onclick="resetSettings()">Сбросить</button>
                    <button class="btn btn-primary" onclick="saveSettings()">Сохранить</button>
                </div>
            </div>

            <div class="card">
                <div class="card-header"><h3 class="card-title">История рабочих сессий</h3></div>

                <div class="table-container">
                    <table class="table" >
                        <thead><tr><th>Дата</th><th>Начало</th><th>Конец</th><th>Длительность</th></tr></thead>
                        <tbody id ="workDayHistory">
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div id="reportsPage" class="page-content hidden">
            <div style="display:flex; justify-content: space-between; align-items:center; margin-bottom:30px; flex-wrap:wrap; gap:15px;">
                <h1 style="display:flex; align-items:center; gap:15px;">
                    <i class="fas fa-chart-bar" style="color: var(--primary);"></i> Отчеты и аналитика
                </h1>
                <div style="display:flex; gap:10px; flex-wrap:wrap;">
                    <button class="btn btn-outline" onclick="exportReport('csv')">
                        <i class="fas fa-file-csv"></i> CSV
                    </button>
                    <button class="btn btn-outline" onclick="exportReport('excel')">
                        <i class="fas fa-file-excel"></i> Excel
                    </button>
                    <button class="btn btn-outline" onclick="exportReport('word')">
                        <i class="fas fa-file-word"></i> Word
                    </button>
                    <button class="btn btn-outline" onclick="exportReport('pdf')">
                        <i class="fas fa-file-pdf"></i> PDF
                    </button>
                    <button class="btn btn-primary" onclick="exportReport('print')">
                        <i class="fas fa-print"></i> Печать
                    </button>
                </div>
            </div>

            <div class="card">
                <div style="display:flex; gap:15px; align-items:center; flex-wrap:wrap;">
                    <div class="date-range-old">
                        <input type="date" class="date-input-old" id="reportDateFrom" value="2026-03-01">
                        <span>—</span>
                        <input type="date" class="date-input-old" id="reportDateTo" value="2026-03-26">
                        <button class="btn btn-primary" onclick="updateReports()"><i class="fas fa-sync-alt"></i> Обновить</button>
                    </div>
                </div>
            </div>

            <div class="filters-bar">
                <div class="filter-group">
                    <i class="fas fa-user"></i>
                    <select class="filter-select" id="employeeFilter" onchange="filterReports()">
                        <option value="all">Все сотрудники</option>
                    </select>
                </div>

                <div class="filter-group">
                    <i class="fas fa-project-diagram"></i>
                    <select class="filter-select" id="reportProjectFilter" onchange="filterReports()">
                        <option value="all">Все проекты</option>
                    </select>
                </div>
            </div>

            <div class="reports-layout">
                <div class="reports-sidebar">
                    <ul class="reports-menu">
                        <li class="reports-menu-item">
                            <a class="reports-menu-link active" onclick="showReport('daily', this)">
                                <i class="fas fa-calendar-day"></i> Ежедневный отчет
                            </a>
                        </li>
                        <li class="reports-menu-item">
                            <a class="reports-menu-link" onclick="showReport('weekly', this)">
                                <i class="fas fa-calendar-week"></i> Недельный отчет
                            </a>
                        </li>
                        <li class="reports-menu-item">
                            <a class="reports-menu-link" onclick="showReport('monthly', this)">
                                <i class="fas fa-calendar-alt"></i> Месячный отчет
                            </a>
                        </li>
                        <li class="reports-menu-item">
                            <a class="reports-menu-link" onclick="showReport('performance', this)">
                                <i class="fas fa-chart-line"></i> Продуктивность
                            </a>
                        </li>
                        <li class="reports-menu-item">
                            <a class="reports-menu-link" onclick="showReport('overdue', this)">
                                <i class="fas fa-exclamation-triangle"></i> Просроченные задачи
                            </a>
                        </li>
                        <li class="reports-menu-item">
                            <a class="reports-menu-link" onclick="showReport('overtime', this)">
                                <i class="fas fa-clock"></i> Переработки
                            </a>
                        </li>
                        <li class="reports-menu-item">
                            <a class="reports-menu-link" onclick="showReport('bonus', this)">
                                <i class="fas fa-gift"></i> Система бонусов
                            </a>
                        </li>
                    </ul>
                </div>

                <div class="reports-content" id="reportsContent">

                </div>
            </div>
        </div>

        @if (!Model.IsEmployee)
{
        <div id="usersPage" class="page-content hidden">
            <div class="breadcrumb">
                <span><i class="fas fa-home"></i></span>
                <span onclick="showPage('dashboard')" style="cursor: pointer;">Главная панель</span>
                <span>→</span>
                <span class="breadcrumb-item active">Администрирование</span>
            </div>

                <div class="content-header">
                    <h1 class="page-title">
                        <i class="fas fa-user-shield"></i>
                        @(Model.IsAdmin ? "Администрирование" : "Моя команда")
                    </h1>

                    @if (Model.IsAdmin)
                    {
                        <button class="btn btn-primary" onclick="openUserModal()">
                            <i class="fas fa-user-plus"></i> Добавить сотрудника
                        </button>
                    }
                </div>

            <div class="card" style="padding-bottom: 14px;">
                    <div class="admin-tabs">
                        <button type="button" class="admin-tab-btn active" onclick="showAdminTab('employees', this)">
                            <i class="fas fa-users"></i> @(Model.IsAdmin ? "Сотрудники" : "Моя команда")
                        </button>

                        <button type="button" class="admin-tab-btn" onclick="showAdminTab('workload', this)">
                            <i class="fas fa-briefcase"></i> Нагрузка
                        </button>

                        <button type="button" class="admin-tab-btn" onclick="showAdminTab('productivity', this)">
                            <i class="fas fa-chart-line"></i> Производительность
                        </button>

                        @if (Model.IsAdmin)
                        {
                            <button type="button" class="admin-tab-btn" onclick="showAdminTab('salary', this)">
                                <i class="fas fa-wallet"></i> Оплата
                            </button>

                            <button type="button" class="admin-tab-btn" onclick="showAdminTab('bonuses', this)">
                                <i class="fas fa-gift"></i> Бонусы
                            </button>
                        }

                        <button type="button" class="admin-tab-btn" onclick="showAdminTab('control', this)">
                            <i class="fas fa-shield-alt"></i> Контроль
                        </button>

                        <button type="button" class="admin-tab-btn" onclick="showAdminTab('calendar', this)">
                            <i class="fas fa-calendar-alt"></i> Календарь
                        </button>
                    </div>
            </div>

            <div id="adminEmployeesTab" class="admin-tab-content">
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-icon"><i class="fas fa-users"></i></div>
                        <div class="stat-info">
                            <div class="stat-value" id="adminEmployeesTotal">0</div>
                            <div class="stat-label">Всего сотрудников</div>
                        </div>
                    </div>

                    <div class="stat-card">
                        <div class="stat-icon"><i class="fas fa-user-check"></i></div>
                        <div class="stat-info">
                            <div class="stat-value" id="adminEmployeesActive">0</div>
                            <div class="stat-label">Активные</div>
                        </div>
                    </div>

                    <div class="stat-card">
                        <div class="stat-icon"><i class="fas fa-user-tie"></i></div>
