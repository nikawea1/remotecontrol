@page
@model RemoteControl1.Pages.MainPageModel
@{
    ViewData["Title"] = "Главная";
}

<div id="dashboardPage" class="container main-content page-content">
    <div class="page-content">
        <div class="page-header-row">
            <h1 class="page-title">
                <i class="fas fa-tachometer-alt"></i>
                Главная панель
            </h1>

            <div class="page-header-actions">
                <button class="btn btn-success" onclick="startTracker()" id="startDayBtn">
                    <i class="fas fa-play"></i> Начать рабочий день
                </button>
                <button class="btn btn-danger hidden" onclick="stopTracker()" id="stopDayBtn">
                    <i class="fas fa-stop"></i> Завершить рабочий день
                </button>
            </div>
        </div>

        <div class="card dashboard-workday-card">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-business-time"></i>
                    Рабочий день
                </h3>
            </div>

            <div id="workDayStatusContent">
                <div style="color: var(--gray);">Статус рабочего дня загружается...</div>
            </div>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-clock"></i></div>
                <div class="stat-info">
                    <div class="stat-value" id="totalHours">0.0</div>
                    <div class="stat-label">Отработано часов</div>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-tasks"></i></div>
                <div class="stat-info">
                    <div class="stat-value" id="activeTasks">0</div>
                    <div class="stat-label">Активных задач</div>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-project-diagram"></i></div>
                <div class="stat-info">
                    <div class="stat-value" id="activeProjects">0</div>
                    <div class="stat-label">Активных проектов</div>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-calendar-check"></i></div>
                <div class="stat-info">
                    <div class="stat-value" id="completedTasks">0</div>
                    <div class="stat-label">Выполненных задач</div>
                </div>
            </div>
        </div>

        <div class="tracker-box">
            <h2 style="margin-bottom: 10px;">
                <i class="fas fa-stopwatch"></i>
                Трекер времени
            </h2>

            <div class="form-group tracker-task-select-wrap" style="max-width: 320px; margin: 0 auto;">
                <select class="form-control" id="currentTask">
                    <option value="">Выберите задачу</option>
                </select>
            </div>

            <div class="timer" id="timer">00:00:00</div>

            <div class="tracker-actions-row">
                <button class="btn tracker-btn tracker-btn-success" onclick="startTracking()" id="startBtn">
                    <i class="fas fa-play"></i> Старт
                </button>
                <button class="btn tracker-btn tracker-btn-warning" onclick="pauseTracking()" id="pauseBtn">
                    <i class="fas fa-pause"></i> Пауза
                </button>
                <button class="btn tracker-btn tracker-btn-danger" onclick="stopTracking()" id="stopBtn">
                    <i class="fas fa-stop"></i> Стоп
                </button>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Мои задачи на сегодня</h3>
                <a class="btn btn-outline" asp-page="/Tasks">
                    <i class="fas fa-eye"></i> Все задачи
                </a>
            </div>

            <div class="tasks-grid" id="dashboardTasks"></div>
        </div>

        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Быстрый учет времени</h3>
            </div>

            <div class="form-row quick-time-row" style="align-items: flex-end;">
                <div class="form-group" style="flex: 2;">
                    <label class="form-label">Задача</label>
                    <select class="form-control" id="quickTask">
                        <option value="">Выберите задачу</option>
                    </select>
                </div>

                <div class="form-group" style="flex: 1;">
                    <label class="form-label">Часы</label>
                    <input type="number" class="form-control" id="quickHours" step="0.5" min="0.5" value="1">
                </div>

                <div class="form-group" style="flex: 2;">
                    <label class="form-label">Комментарий</label>
                    <input type="text" class="form-control" id="quickComment" placeholder="Что сделано?">
                </div>

                <div class="form-group" style="flex: 2;">
                    <label class="form-label">Файл-пруф</label>
                    <input type="file" class="form-control" id="quickAttachment">
                </div>

                <div class="form-group">
                    <button class="btn btn-primary" onclick="addTimeEntry()" style="height: 42px;">
                        <i class="fas fa-plus"></i> Добавить
                    </button>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Последняя активность</h3>
            </div>

            <div class="table-container">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Дата</th>
                            <th>Задача</th>
                            <th>Время</th>
                            <th>Комментарий</th>
                            <th>Файл</th>
                            <th>Статус</th>
                        </tr>
                    </thead>
                    <tbody id="activityLog"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    window.remoteControlData = {
        currentUserName: '@Html.Raw((Model.UserName ?? "").Replace("'", "\\'"))',
        currentUserEmail: '@Html.Raw((Model.UserEmail ?? "").Replace("'", "\\'"))',
        currentUserLogin: '@Html.Raw((Model.CurrentUserLogin ?? "").Replace("'", "\\'"))',
        currentUserPhone: '@Html.Raw((Model.CurrentUserPhone ?? "").Replace("'", "\\'"))',
        currentUserPosition: '@Html.Raw((Model.CurrentUserPosition ?? "").Replace("'", "\\'"))',
        currentUserRate: @Model.CurrentUserRate.ToString(System.Globalization.CultureInfo.InvariantCulture),
        currentUserIsActive: @Model.CurrentUserIsActive.ToString().ToLower(),
        currentUserId: @Model.CurrentUserId,
        currentUserRole: '@Model.CurrentUserRole',
        isAdmin: @Model.IsAdmin.ToString().ToLower(),
        isManager: @Model.IsManager.ToString().ToLower(),
        isEmployee: @Model.IsEmployee.ToString().ToLower(),
        tasks: @Html.Raw(Model.TasksJson ?? "[]"),
        projects: @Html.Raw(Model.ProjectsJson ?? "[]"),
        activity: @Html.Raw(Model.ActivityJson ?? "[]"),
        users: @Html.Raw(Model.UsersJson ?? "[]"),
        workDays: @Html.Raw(Model.WorkDaysJson ?? "[]"),
        calendarEvents: @Html.Raw(Model.CalendarEventsJson ?? "[]")
    };
</script>

@section Scripts {
    <script src="~/js/dashboard.js" asp-append-version="true"></script>
    <script src="~/js/tasks.js" asp-append-version="true"></script>
    <script src="~/js/projects.js" asp-append-version="true"></script>
    <script src="~/js/users.js" asp-append-version="true"></script>
    <script src="~/js/reports.js" asp-append-version="true"></script>
    <script src="~/js/capture.js" asp-append-version="true"></script>
    <script src="~/js/calendar.js" asp-append-version="true"></script>
}