@model string
@{
    var key = (Model ?? "").Trim().ToLowerInvariant();
    string WrapSvg(string markup)
    {
        const string svgAttrs = "class=\"rc-icon-svg\" style=\"display:block;width:20px;height:20px;color:currentColor;stroke:currentColor;fill:none;overflow:visible\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" focusable=\"false\" width=\"20\" height=\"20\"";
        return markup.Replace("<svg ", $"<svg {svgAttrs} ");
    }

    string svg = key switch
    {
        "brand" => WrapSvg("<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><rect x=\"4\" y=\"5\" width=\"16\" height=\"11\" rx=\"2\"/><path d=\"M9 19h6\"/><path d=\"M12 16v3\"/><path d=\"M9 9h6\"/><path d=\"M8 12h3\"/><path d=\"M13 12h3\"/></svg>"),
        "home" => WrapSvg("<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M3 11.5 12 4l9 7.5\"/><path d=\"M5.5 10.5V20h13v-9.5\"/><path d=\"M9.5 20v-5h5v5\"/></svg>"),
        "dashboard" => WrapSvg("<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M4 14a8 8 0 1 1 16 0\"/><path d=\"M12 14l4-4\"/><path d=\"M12 18v-1\"/></svg>"),
        "tasks" => WrapSvg("<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><rect x=\"7\" y=\"3\" width=\"10\" height=\"18\" rx=\"2\"/><path d=\"M9 8h6\"/><path d=\"M9 13h6\"/><path d=\"M9 18h6\"/><path d=\"M4.5 8.5l1.5 1.5 2-2\"/><path d=\"M4.5 13.5l1.5 1.5 2-2\"/></svg>"),
        "projects" => WrapSvg("<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M3 7h7v5H3z\"/><path d=\"M14 4h7v5h-7z\"/><path d=\"M14 15h7v5h-7z\"/><path d=\"M10 9h4\"/><path d=\"M12 9v8\"/></svg>"),
        "tracker" => WrapSvg("<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"13\" r=\"7\"/><path d=\"M12 13l3-2\"/><path d=\"M9 3h6\"/><path d=\"M12 6V4\"/></svg>"),
        "reports" => WrapSvg("<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M5 19V9\"/><path d=\"M12 19V5\"/><path d=\"M19 19v-7\"/><path d=\"M3 19h18\"/></svg>"),
        "calendar" => WrapSvg("<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><rect x=\"3\" y=\"5\" width=\"18\" height=\"16\" rx=\"2\"/><path d=\"M3 10h18\"/><path d=\"M8 3v4\"/><path d=\"M16 3v4\"/></svg>"),
        "users" => WrapSvg("<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><circle cx=\"9\" cy=\"9\" r=\"3\"/><circle cx=\"17\" cy=\"10\" r=\"2.5\"/><path d=\"M4 19a5 5 0 0 1 10 0\"/><path d=\"M14.5 19a3.5 3.5 0 0 1 5-3\"/></svg>"),
        "profile" => WrapSvg("<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"8\" r=\"3.5\"/><path d=\"M5 20a7 7 0 0 1 14 0\"/></svg>"),
        "settings" => WrapSvg("<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M4 6h8\"/><path d=\"M16 6h4\"/><circle cx=\"14\" cy=\"6\" r=\"2\"/><path d=\"M4 12h4\"/><path d=\"M12 12h8\"/><circle cx=\"10\" cy=\"12\" r=\"2\"/><path d=\"M4 18h10\"/><path d=\"M18 18h2\"/><circle cx=\"16\" cy=\"18\" r=\"2\"/></svg>"),
        "clock" => WrapSvg("<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"8\"/><path d=\"M12 8v4l3 2\"/></svg>"),
        "done" => WrapSvg("<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"8\"/><path d=\"M8.5 12.5l2.2 2.2 4.8-5\"/></svg>"),
        "folder" => WrapSvg("<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M3 8h6l2 2h10v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z\"/><path d=\"M3 8V6a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2\"/></svg>"),
        "user-slash" => WrapSvg("<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><circle cx=\"10\" cy=\"8\" r=\"3\"/><path d=\"M4 19a6 6 0 0 1 8-5\"/><path d=\"M4 4l16 16\"/></svg>"),
        "briefcase" => WrapSvg("<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><rect x=\"3\" y=\"7\" width=\"18\" height=\"12\" rx=\"2\"/><path d=\"M9 7V5a1.5 1.5 0 0 1 1.5-1.5h3A1.5 1.5 0 0 1 15 5v2\"/><path d=\"M3 12h18\"/></svg>"),
        "shield" => WrapSvg("<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M12 3l7 3v5c0 4.5-2.7 7.7-7 10-4.3-2.3-7-5.5-7-10V6z\"/><path d=\"M12 7v10\"/></svg>"),
        "money" => WrapSvg("<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><rect x=\"3\" y=\"6\" width=\"18\" height=\"12\" rx=\"2\"/><circle cx=\"12\" cy=\"12\" r=\"2.5\"/><path d=\"M7 9h.01\"/><path d=\"M17 15h.01\"/></svg>"),
        "warning" => WrapSvg("<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M12 4l8 14H4z\"/><path d=\"M12 10v4\"/><path d=\"M12 17h.01\"/></svg>"),
        "hourglass" => WrapSvg("<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M7 4h10\"/><path d=\"M7 20h10\"/><path d=\"M8 4c0 4 4 4 4 8s-4 4-4 8\"/><path d=\"M16 4c0 4-4 4-4 8s4 4 4 8\"/></svg>"),
        "user-check" => WrapSvg("<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><circle cx=\"9\" cy=\"8\" r=\"3\"/><path d=\"M4 19a5 5 0 0 1 10 0\"/><path d=\"M16 11l2 2 3-4\"/></svg>"),
        "pause" => WrapSvg("<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"8\"/><path d=\"M10 9v6\"/><path d=\"M14 9v6\"/></svg>"),
        _ => WrapSvg("<svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"8\"/></svg>")
    };
}
@Html.Raw(svg)
