@using Microsoft.AspNetCore.Http
@{
    var sessionUserName = Context.Session.GetString("user_name") ?? "Пользователь";
    var sessionUserEmail = Context.Session.GetString("user_email") ?? "";
    var sessionUserRole = (Context.Session.GetString("user_role") ?? "employee").ToLower();

    var avatarLetter = "U";
    if (!string.IsNullOrWhiteSpace(sessionUserName))
    {
        avatarLetter = sessionUserName.Trim().Substring(0, 1).ToUpper();
    }

    string roleText = sessionUserRole switch
    {
        "admin" => "Администратор",
        "manager" => "Руководитель",
        _ => "Сотрудник"
    };

    bool isAdmin = sessionUserRole == "admin";
    bool isManager = sessionUserRole == "manager";
    bool isEmployee = !isAdmin && !isManager;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Remote Control</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/common.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modals.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/notifications.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tasks.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/projects.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/reports.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/calendar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/profile.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tracker.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/users.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RemoteControl1.styles.css" asp-append-version="true" />

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
</head>
<body>
    @Html.AntiForgeryToken()

    <nav class="navbar">
        <div class="container nav-container">
            <div class="nav-logo">
                <i class="fas fa-clock"></i>
                REMOTE CONTROL
            </div>

            <ul class="nav-menu">
                <li>
                    <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/MainPage" ? "active" : "")" asp-page="/MainPage">
                        <i class="fas fa-home"></i>
                        <span>Главная</span>
                    </a>
                </li>

                <li>
                    <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Tasks" ? "active" : "")" asp-page="/Tasks">
                        <i class="fas fa-tasks"></i>
                        <span>Задачи</span>
                    </a>
                </li>

                <li>
                    <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Projects" ? "active" : "")" asp-page="/Projects">
                        <i class="fas fa-project-diagram"></i>
                        <span>Проекты</span>
                    </a>
                </li>

                <li>
                    <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Tracker" ? "active" : "")" asp-page="/Tracker">
                        <i class="fas fa-stopwatch"></i>
                        <span>Трекер</span>
                    </a>
                </li>

                <li>
                    <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Reports" ? "active" : "")" asp-page="/Reports">
                        <i class="fas fa-chart-bar"></i>
                        <span>Отчеты</span>
                    </a>
                </li>

                <li>
                    <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Calendar" ? "active" : "")" asp-page="/Calendar">
                        <i class="fas fa-calendar-alt"></i>
                        <span>Календарь</span>
                    </a>
                </li>

                @if (!isEmployee)
                {
                    <li>
                        <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Users" ? "active" : "")" asp-page="/Users">
                            <i class="fas fa-users"></i>
                            <span>Сотрудники</span>
                        </a>
                    </li>
                }
            </ul>

            <div class="nav-right">
                <div class="header-user-block" onclick="toggleProfileDropdown()" id="headerUserBlock">
                    <div class="header-user-text-wrap">
                        <div class="header-user-name" id="userNameHeader">@sessionUserName</div>
                        <div class="header-user-role @(sessionUserRole == "admin" ? "is-admin" : "")" id="userRoleHeader">@roleText</div>
                    </div>

                    <div class="header-user-avatar" id="userAvatar">
                        @avatarLetter
                    </div>

                    <div class="profile-dropdown" id="profileDropdown">
                        <div class="profile-dropdown-header">
                            <div class="profile-dropdown-avatar" id="dropdownAvatar">@avatarLetter</div>
                            <div class="profile-dropdown-info">
                                <h4 id="dropdownName">@sessionUserName</h4>
                                <p id="dropdownRole">@roleText</p>
                                <p style="margin-top:6px; font-size:13px; color: rgba(255,255,255,0.85);" id="dropdownEmail">@sessionUserEmail</p>
                            </div>
                        </div>

                        <div class="profile-dropdown-menu">
                            <div class="profile-dropdown-item" onclick="window.location.href='@Url.Page("/Profile")'">
                                <i class="fas fa-user"></i>
                                <span>Мой профиль</span>
                            </div>

                            <div class="profile-dropdown-divider"></div>

                            <div class="profile-dropdown-item" onclick="logout()">
                                <i class="fas fa-sign-out-alt"></i>
                                <span>Выйти</span>
                            </div>
                        </div>

                        <div class="profile-dropdown-footer">
                            <span><i class="far fa-clock"></i> Рабочая панель</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <main role="main">
        @RenderBody()
    </main>

    <div class="bottom-tracker-shell collapsed" id="bottomTrackerShell">
        <button class="bottom-tracker-toggle" type="button" onclick="toggleBottomTracker()" id="bottomTrackerToggle" title="Развернуть таймер">
            <i class="fas fa-chevron-up" id="bottomTrackerToggleIcon"></i>
        </button>

        <div class="bottom-tracker-card" id="bottomTracker">
            <div class="bottom-tracker-top">
                <div class="bottom-tracker-state" id="bottomTrackerStateBox">
                    <span class="status-dot stopped" id="statusDot"></span>
                    <span id="statusText">Не активен</span>
                </div>
            </div>

            <div class="bottom-tracker-main-row">
                <div class="bottom-tracker-time-wrap">
                    <div class="bottom-tracker-time" id="bottomTimer">00:00:00</div>
                </div>

                <div class="bottom-tracker-actions-collapsed" id="bottomTrackerCollapsedActions">
                    <button class="bottom-main-action" type="button" onclick="handleBottomMainAction()" id="bottomMainActionBtn">
                        <i class="fas fa-play" id="bottomMainActionIcon"></i>
                    </button>
                </div>
            </div>

            <div class="bottom-tracker-actions-expanded" id="bottomTrackerExpandedActions">
                <button class="btn bottom-control-btn start" type="button" onclick="startTracking()" id="bottomStartBtn">
                    <i class="fas fa-play"></i>
                    <span>Старт</span>
                </button>

                <button class="btn bottom-control-btn pause" type="button" onclick="pauseTracking()" id="bottomPauseBtn">
                    <i class="fas fa-pause"></i>
                    <span>Пауза</span>
                </button>

                <button class="btn bottom-control-btn stop" type="button" onclick="stopTracking()" id="bottomStopBtn">
                    <i class="fas fa-stop"></i>
                    <span>Стоп</span>
                </button>
            </div>
        </div>
    </div>

    <div id="notification" class="notification hidden">
        <div style="display:flex; align-items:center; gap:10px;">
            <i class="fas fa-info-circle" style="color: var(--primary); font-size: 20px;"></i>
            <div id="notificationMessage">Уведомление</div>
        </div>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/modals.js" asp-append-version="true"></script>
    <script src="~/js/notify.js" asp-append-version="true"></script>
    <script src="~/js/timer.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>