@* Файл: RemoteControl1/Pages/Shared/_Layout.cshtml *@
@using Microsoft.AspNetCore.Http
@{
    var sessionUserName = Context.Session.GetString("user_name") ?? "Пользователь";
    var sessionUserEmail = Context.Session.GetString("user_email") ?? "";
    var sessionUserRole = (Context.Session.GetString("user_role") ?? "employee").ToLower();

    var avatarLetter = "U";
    if (!string.IsNullOrWhiteSpace(sessionUserName))
    {
        avatarLetter = sessionUserName.Trim().Substring(0, 1).ToUpper();
    }

    string roleText = sessionUserRole switch
    {
        "admin" => "Администратор",
        "manager" => "Руководитель",
        _ => "Сотрудник"
    };

    bool isAdmin = sessionUserRole == "admin";
    bool isManager = sessionUserRole == "manager";
    bool isEmployee = !isAdmin && !isManager;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Remote Control</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/common.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modals.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/notifications.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tasks.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/projects.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/reports.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/calendar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/profile.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tracker.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/users.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/design-system.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RemoteControl1.styles.css" asp-append-version="true" />

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
</head>
<body>
    @Html.AntiForgeryToken()

    <div class="app-shell" id="appShell">
        <aside class="app-sidebar" id="appSidebar" aria-label="Основная навигация">
            <div class="sidebar-brand-row">
                <a class="sidebar-brand" asp-page="/MainPage" aria-label="Remote Control">
                    <span class="sidebar-brand-icon" aria-hidden="true">
                        <i class="fas fa-table-columns"></i>
                    </span>
                    <span class="sidebar-brand-text">REMOTE CONTROL</span>
                </a>

                <button class="sidebar-collapse-btn" type="button" onclick="toggleSidebar()" aria-label="Свернуть меню" title="Меню">
                    <i class="fas fa-bars"></i>
                </button>
            </div>

            <nav class="sidebar-nav">
                <a class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/MainPage" ? "active" : "")" asp-page="/MainPage">
                    <i class="fas fa-house-chimney"></i>
                    <span>Главная</span>
                </a>

                <a class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Tasks" ? "active" : "")" asp-page="/Tasks">
                    <i class="fas fa-list-check"></i>
                    <span>Задачи</span>
                </a>

                <a class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Projects" ? "active" : "")" asp-page="/Projects">
                    <i class="fas fa-layer-group"></i>
                    <span>Проекты</span>
                </a>

                <a class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Tracker" ? "active" : "")" asp-page="/Tracker">
                    <i class="fas fa-stopwatch"></i>
                    <span>Трекер</span>
                </a>

                <a class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Reports" ? "active" : "")" asp-page="/Reports">
                    <i class="fas fa-chart-simple"></i>
                    <span>Отчеты</span>
                </a>

                <a class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Calendar" ? "active" : "")" asp-page="/Calendar">
                    <i class="far fa-calendar-days"></i>
                    <span>Календарь</span>
                </a>

                @if (!isEmployee)
                {
                    <a class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Users" ? "active" : "")" asp-page="/Users">
                        <i class="fas fa-user-group"></i>
                        <span>Сотрудники</span>
                    </a>
                }

                <div class="sidebar-nav-divider" role="separator" aria-label="Аккаунт"></div>
                <div class="sidebar-nav-section-label">Аккаунт</div>

                <a class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Profile" ? "active" : "")" asp-page="/Profile">
                    <i class="far fa-user"></i>
                    <span>Профиль</span>
                </a>

                <a class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Settings" ? "active" : "")" asp-page="/Settings">
                    <i class="fas fa-sliders"></i>
                    <span>Настройки</span>
                </a>
            </nav>
        </aside>

        <button class="sidebar-backdrop" id="sidebarBackdrop" type="button" onclick="closeSidebarMobile()" aria-label="Закрыть меню"></button>

        <div class="app-main">
            <header class="app-topbar">
                <div class="topbar-left">
                    <button class="topbar-menu-btn" type="button" onclick="toggleSidebar()" aria-label="Открыть меню" title="Меню">
                        <i class="fas fa-bars"></i>
                    </button>

                    <div class="topbar-page">
                        <span>Remote Control</span>
                        <strong>@(ViewData["Title"] ?? "Панель")</strong>
                    </div>
                </div>

                <div class="nav-right">
                <div class="nav-utilities">
                    <button class="nav-utility-btn nav-theme-btn" type="button" onclick="toggleThemePlaceholder()" title="Тёмная тема" aria-label="Тёмная тема">
                        <i class="fas fa-moon"></i>
                    </button>

                    <div class="nav-notifications" id="navNotifications">
                        <button class="nav-utility-btn nav-notifications-btn" type="button" onclick="toggleNotificationsDropdown(event)" title="Уведомления" aria-label="Уведомления">
                            <i class="far fa-bell"></i>
                            <span class="nav-utility-dot hidden" id="navNotificationsDot"></span>
                        </button>

                        <div class="notifications-dropdown" id="notificationsDropdown">
                            <div class="notifications-dropdown-header">
                                <div>
                                    <strong>Уведомления</strong>
                                    <span>События по задачам, заявкам и проверкам</span>
                                </div>
                                <span class="notifications-dropdown-badge hidden" id="notificationsUnreadBadge">0</span>
                            </div>

                            <div class="notifications-dropdown-list" id="notificationsDropdownList">
                                <div class="notifications-dropdown-empty">Загрузка уведомлений...</div>
                            </div>

                            <div class="notifications-dropdown-footer">
                                <button class="notifications-dropdown-action" type="button" onclick="markAllNotificationsAsRead()">
                                    Отметить как просмотренные
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="header-user-block" onclick="toggleProfileDropdown()" id="headerUserBlock">
                    <div class="header-user-text-wrap">
                        <div class="header-user-name" id="userNameHeader">@sessionUserName</div>
                        <div class="header-user-role @(sessionUserRole == "admin" ? "is-admin" : "")" id="userRoleHeader">@roleText</div>
                    </div>

                    <div class="header-user-avatar" id="userAvatar">
                        @avatarLetter
                    </div>

                    <div class="profile-dropdown" id="profileDropdown">
                        <div class="profile-dropdown-header">
                            <div class="profile-dropdown-avatar" id="dropdownAvatar">@avatarLetter</div>
                            <div class="profile-dropdown-info">
                                <h4 id="dropdownName">@sessionUserName</h4>
                                <p id="dropdownRole">@roleText</p>
                                <p class="profile-dropdown-email" id="dropdownEmail">@sessionUserEmail</p>
                            </div>
                        </div>

                        <div class="profile-dropdown-menu">
                            <div class="profile-dropdown-item" onclick="window.location.href='@Url.Page("/Profile")'">
                                <i class="fas fa-user"></i>
                                <span>Мой профиль</span>
                            </div>

                            <div class="profile-dropdown-item" onclick="window.location.href='@Url.Page("/Settings")'">
                                <i class="fas fa-sliders"></i>
                                <span>Настройки</span>
                            </div>

                            <div class="profile-dropdown-divider"></div>

                            <div class="profile-dropdown-item" onclick="logout()">
                                <i class="fas fa-sign-out-alt"></i>
                                <span>Выйти</span>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
            </header>

            <main role="main" class="app-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <div class="bottom-tracker-shell collapsed" id="bottomTrackerShell">
        <button class="bottom-tracker-toggle" type="button" onclick="toggleBottomTracker()" id="bottomTrackerToggle" title="Развернуть таймер">
            <i class="fas fa-chevron-up" id="bottomTrackerToggleIcon"></i>
        </button>

        <div class="bottom-tracker-card" id="bottomTracker">
            <div class="bottom-tracker-top">
                <div class="bottom-tracker-state" id="bottomTrackerStateBox">
                    <span class="status-dot stopped" id="statusDot"></span>
                    <span id="statusText">Не активен</span>
                </div>
            </div>

            <div class="bottom-tracker-main-row">
                <div class="bottom-tracker-time-wrap">
                    <div class="bottom-tracker-time" id="bottomTimer">00:00:00</div>
                </div>

                <div class="bottom-tracker-actions-collapsed" id="bottomTrackerCollapsedActions">
                    <button class="bottom-main-action" type="button" onclick="handleBottomMainAction()" id="bottomMainActionBtn">
                        <i class="fas fa-play" id="bottomMainActionIcon"></i>
                    </button>
                </div>
            </div>

            <div class="bottom-tracker-actions-expanded" id="bottomTrackerExpandedActions">
                <button class="btn bottom-control-btn start" type="button" onclick="startTracking()" id="bottomStartBtn">
                    <i class="fas fa-play"></i>
                    <span>Старт</span>
                </button>

                <button class="btn bottom-control-btn pause" type="button" onclick="pauseTracking()" id="bottomPauseBtn">
                    <i class="fas fa-pause"></i>
                    <span>Пауза</span>
                </button>

                <button class="btn bottom-control-btn stop" type="button" onclick="stopTracking()" id="bottomStopBtn">
                    <i class="fas fa-stop"></i>
                    <span>Стоп</span>
                </button>
            </div>
        </div>
    </div>

    <div id="notification" class="notification hidden">
        <div class="notification-content">
            <i class="fas fa-circle-info"></i>
            <div id="notificationMessage">Уведомление</div>
        </div>
    </div>

    <script src="https://unpkg.com/lucide@0.487.0/dist/umd/lucide.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/modals.js" asp-append-version="true"></script>
    <script src="~/js/notify.js" asp-append-version="true"></script>
    <script src="~/js/capture.js" asp-append-version="true"></script>
    <script src="~/js/timer.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
